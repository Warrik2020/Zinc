        s is VecToken.get_start(self->toks, pos);
        return Codegen.byte_at(self, s + 0) == 101 &&
               Codegen.byte_at(self, s + 1) == 110 &&
               Codegen.byte_at(self, s + 2) == 117 &&
               Codegen.byte_at(self, s + 3) == 109;
    }
