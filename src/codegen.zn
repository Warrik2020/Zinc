    # Enum variant table record stride = 4:
    # 0 enum_idx, 1 name_start, 2 name_len, 3 value
    func int enum_variant_find_value(int* self, int enum_idx, int name_start, int name_len) {
        if (self->enum_vals == 0) { return -1; }
        n is VecInt.count(self->enum_vals) / 4;
        for (int i is 0; i < n; i is i + 1) {
            if (VecInt.get(self->enum_vals, i * 4 + 0) != enum_idx) { continue; }
            if (VecInt.get(self->enum_vals, i * 4 + 2) != name_len) { continue; }
            s is VecInt.get(self->enum_vals, i * 4 + 1);
            ok is 1;
            for (int j is 0; j < name_len; j is j + 1) {
                if (Codegen.byte_at(self, s + j) != Codegen.byte_at(self, name_start + j)) { ok is 0; break; }
            }
            if (ok == 1) { return VecInt.get(self->enum_vals, i * 4 + 3); }
        }
        return -1;
    }

    func int type_ty_at(int* self, int pos) {
        if (Codegen.tok_is_int(self, pos) == 1) { return TY_INT; }
        if (Codegen.tok_is_float_kw(self, pos) == 1) { return TY_INT; }
        if (Codegen.tok_is_bool_kw(self, pos) == 1) { return TY_INT; }
        if (Codegen.tok_is_string_kw(self, pos) == 1) { return TY_STRING; }
        if (Codegen.tok_is_void_kw(self, pos) == 1) { return TY_VOID; }
        if (VecToken.get_kind(self->toks, pos) == TK_IDENT) {
            ns is VecToken.get_start(self->toks, pos);
            nl is VecToken.get_len(self->toks, pos);
            cidx is Codegen.class_find_by_name(self, ns, nl);
            if (cidx >= 0) { return TY_CLASS_BASE + cidx; }
            eidx is Codegen.enum_find_by_name(self, ns, nl);
            if (eidx >= 0) { return TY_ENUM_BASE + eidx; }
        }
        return 0;
    }

    # Field table record stride = 4:
    # 0 class_idx, 1 name_start, 2 name_len, 3 offset_bytes
    func int field_offset(int* self, int class_idx, int name_start, int name_len) {
        if (self->fields == 0) { return -1; }
        n is VecInt.count(self->fields) / 4;
        for (int i is 0; i < n; i is i + 1) {
            if (VecInt.get(self->fields, i * 4 + 0) != class_idx) { continue; }
            nl is VecInt.get(self->fields, i * 4 + 2);
            if (nl != name_len) { continue; }
            ns is VecInt.get(self->fields, i * 4 + 1);
            ok is 1;
            for (int j is 0; j < name_len; j is j + 1) {
                if (Codegen.byte_at(self, ns + j) != Codegen.byte_at(self, name_start + j)) { ok is 0; break; }
            }
            if (ok == 1) { return VecInt.get(self->fields, i * 4 + 3); }
        }
        return -1;
    }

    # Method lookup in `self->fns` (kind=1).
    func int method_find_func(int* self, int class_idx, int name_start, int name_len) {
        if (self->fns == 0) { return -1; }
        n is VecInt.count(self->fns) / 12;
        for (int i is 0; i < n; i is i + 1) {
            if (VecInt.get(self->fns, i * 12 + 0) != 1) { continue; }
            if (VecInt.get(self->fns, i * 12 + 1) != class_idx) { continue; }
            nl is VecInt.get(self->fns, i * 12 + 5);
            if (nl != name_len) { continue; }
            ns is VecInt.get(self->fns, i * 12 + 4);
            ok is 1;
            for (int j is 0; j < name_len; j is j + 1) {
                if (Codegen.byte_at(self, ns + j) != Codegen.byte_at(self, name_start + j)) { ok is 0; break; }
            }
            if (ok == 1) { return i; }
        }
        return -1;
    }

    func int find_main_body(int* self, int* out_lbrace, int* out_rbrace) {
        i is 0;
        while (i < self->tok_count && VecToken.get_kind(self->toks, i) != TK_EOF) {
            if (i + 2 < self->tok_count) {
                if (Codegen.tok_is_func(self, i) == 0) { i is i + 1; continue; }
                if (Codegen.tok_is_int(self, i + 1) == 0) { i is i + 1; continue; }
                if (Codegen.tok_is_main(self, i + 2) == 0) { i is i + 1; continue; }

                j is i + 3;
                while (j < self->tok_count && VecToken.get_kind(self->toks, j) != TK_EOF) {
                    if (Codegen.tok_punct1(self, j, 123) == 1) {
                        *out_lbrace is j;
                        depth is 1;
                        k is j + 1;
                        while (k < self->tok_count && VecToken.get_kind(self->toks, k) != TK_EOF && depth > 0) {
                            if (VecToken.get_kind(self->toks, k) == TK_PUNCT) {
                                if (Codegen.tok_punct1(self, k, 123) == 1) { depth is depth + 1; }
                                else if (Codegen.tok_punct1(self, k, 125) == 1) { depth is depth - 1; }
                            }
                            k is k + 1;
                        }
                        if (depth != 0) { return 0; }
                        *out_rbrace is k - 1;
                        return 1;
                    }
                    j is j + 1;
                }
            }
            i is i + 1;
        }
        return 0;
    }

    # Expression parser (returns TY_*, leaves value in %rax when emitting)

    func int parse_expr(int* self, int* pos) { return Codegen.parse_or(self, pos); }

    func int parse_or(int* self, int* pos) {
        ty is Codegen.parse_and(self, pos);
        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct2(self, *pos, 124, 124) == 1) {
            *pos is *pos + 1;
            if (ty != TY_INT) { cg_error("|| expects int"); }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_and(self, pos);
            if (rty != TY_INT) { cg_error("|| expects int"); }
            if (self->emit == 1) {
                # result = (lhs != 0) || (rhs != 0)
                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
                Codegen.emit_line_bitness(self, "    testq %r10, %r10", "    testl %ebx, %ebx");
                Codegen.emit_line_bitness(self, "    setne %r10b", "    setne %bl");
                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
                Codegen.emit_line(self, "    setne %al");
                Codegen.emit_line_bitness(self, "    orb %r10b, %al", "    orb %bl, %al");
                Codegen.emit_line(self, "    movzbl %al, %eax");
            }
            ty is TY_INT;
        }
        return ty;
    }

	    func int parse_and(int* self, int* pos) {
	        ty is Codegen.parse_bitor(self, pos);
	        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct2(self, *pos, 38, 38) == 1) {
	            *pos is *pos + 1;
	            if (ty != TY_INT) { cg_error("&& expects int"); }
		            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
	            rty is Codegen.parse_bitor(self, pos);
	            if (rty != TY_INT) { cg_error("&& expects int"); }
	            if (self->emit == 1) {
	                # result = (lhs != 0) && (rhs != 0)
	                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
	                Codegen.emit_line_bitness(self, "    testq %r10, %r10", "    testl %ebx, %ebx");
	                Codegen.emit_line_bitness(self, "    setne %r10b", "    setne %bl");
	                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
	                Codegen.emit_line(self, "    setne %al");
	                Codegen.emit_line_bitness(self, "    andb %r10b, %al", "    andb %bl, %al");
	                Codegen.emit_line(self, "    movzbl %al, %eax");
	            }
            ty is TY_INT;
        }
	        return ty;
	    }

	    # Bitwise OR/XOR/AND (int-only). Lower precedence than ==/!= and higher than &&.

	    func int parse_bitor(int* self, int* pos) {
	        ty is Codegen.parse_bitxor(self, pos);
	        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
	               Codegen.tok_punct1(self, *pos, 124) == 1) {
	            op_pos is *pos;
	            *pos is *pos + 1;
	            if (ty != TY_INT) { Codegen.error_at(self, "| expects int", op_pos); }
		            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
	            rty is Codegen.parse_bitxor(self, pos);
	            if (rty != TY_INT) { Codegen.error_at(self, "| expects int", op_pos); }
		            if (self->emit == 1) {
		                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
		                Codegen.emit_line_bitness(self, "    orq %r10, %rax", "    orl %ebx, %eax");
		            }
	            ty is TY_INT;
	        }
	        return ty;
	    }

	    func int parse_bitxor(int* self, int* pos) {
	        ty is Codegen.parse_bitand(self, pos);
	        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
	               Codegen.tok_punct1(self, *pos, 94) == 1) {
	            op_pos is *pos;
	            *pos is *pos + 1;
	            if (ty != TY_INT) { Codegen.error_at(self, "^ expects int", op_pos); }
		            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
	            rty is Codegen.parse_bitand(self, pos);
	            if (rty != TY_INT) { Codegen.error_at(self, "^ expects int", op_pos); }
		            if (self->emit == 1) {
		                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
		                Codegen.emit_line_bitness(self, "    xorq %r10, %rax", "    xorl %ebx, %eax");
		            }
	            ty is TY_INT;
	        }
	        return ty;
	    }

	    # Bitwise AND: expr '&' expr (int-only). Lower precedence than ==/!= and higher than ^ and |.
	    func int parse_bitand(int* self, int* pos) {
	        ty is Codegen.parse_eq(self, pos);
	        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
	               Codegen.tok_punct1(self, *pos, 38) == 1) {
            op_pos is *pos;
            *pos is *pos + 1;
            if (ty != TY_INT) { Codegen.error_at(self, "& expects int", op_pos); }
	            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_eq(self, pos);
            if (rty != TY_INT) { Codegen.error_at(self, "& expects int", op_pos); }
	            if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
	                Codegen.emit_line_bitness(self, "    andq %r10, %rax", "    andl %ebx, %eax");
	            }
            ty is TY_INT;
        }
        return ty;
    }

    func int parse_eq(int* self, int* pos) {
        ty is Codegen.parse_rel(self, pos);
        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
               (Codegen.tok_punct2(self, *pos, 61, 61) == 1 || Codegen.tok_punct2(self, *pos, 33, 61) == 1)) {
            is_ne is Codegen.tok_punct2(self, *pos, 33, 61);
            *pos is *pos + 1;
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_rel(self, pos);
                if (ty == TY_STRING || rty == TY_STRING) {
	                    if (ty != TY_STRING || rty != TY_STRING) { cg_error("==/!= type mismatch"); }
	                    if (self->emit == 1) {
	                        # strcmp(lhs, rhs) == 0
	                        if (self->bitness == 32) {
	                            Codegen.emit_line(self, "    popl %ebx");
	                            Codegen.emit_call_prep(self, 2);
	                            Codegen.emit_line(self, "    pushl %eax");
	                            Codegen.emit_line(self, "    pushl %ebx");
	                            Codegen.emit_line(self, "    call __zinc_rt_strcmp");
	                            Codegen.emit_call_cleanup(self, 2);
	                        } else {
	                            Codegen.emit_line(self, "    movq %rax, %rsi");
	                            Codegen.emit_line(self, "    popq %rdi");
	                            Codegen.emit_line(self, "    call __zinc_rt_strcmp");
	                        }
	                        Codegen.emit_line(self, "    cmpl $0, %eax");
                        if (is_ne == 1) { Codegen.emit_line(self, "    setne %al"); }
                        else { Codegen.emit_line(self, "    sete %al"); }
                        Codegen.emit_line(self, "    movzbl %al, %eax");
                    } else {
                        # prepass: pop the pushed lhs to keep token walk consistent
                }
            } else {
                if (ty != TY_INT && ty != TY_STR_ARR && is_class_ptr_ty(ty) == 0) { cg_error("==/!= expects int"); }
	                if (rty != TY_INT && rty != TY_STR_ARR && is_class_ptr_ty(rty) == 0) { cg_error("==/!= expects int"); }
	                if (self->emit == 1) {
	                    Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
	                    Codegen.emit_line_bitness(self, "    cmpq %rax, %r10", "    cmpl %eax, %ebx");
	                    if (is_ne == 1) { Codegen.emit_line(self, "    setne %al"); }
	                    else { Codegen.emit_line(self, "    sete %al"); }
	                    Codegen.emit_line(self, "    movzbl %al, %eax");
	                }
            }
            ty is TY_INT;
        }
        return ty;
    }

    func int parse_rel(int* self, int* pos) {
        ty is Codegen.parse_add(self, pos);
        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
               (Codegen.tok_punct1(self, *pos, 60) == 1 || Codegen.tok_punct1(self, *pos, 62) == 1 ||
                Codegen.tok_punct2(self, *pos, 60, 61) == 1 || Codegen.tok_punct2(self, *pos, 62, 61) == 1)) {
            is_lt is Codegen.tok_punct1(self, *pos, 60);
            is_gt is Codegen.tok_punct1(self, *pos, 62);
            is_le is Codegen.tok_punct2(self, *pos, 60, 61);
            is_ge is Codegen.tok_punct2(self, *pos, 62, 61);
            *pos is *pos + 1;
            if (ty != TY_INT) { cg_error("comparison expects int"); }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_add(self, pos);
            if (rty != TY_INT) { cg_error("comparison expects int"); }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
                Codegen.emit_line_bitness(self, "    cmpq %rax, %r10", "    cmpl %eax, %ebx");
                if (is_lt == 1) { Codegen.emit_line(self, "    setl %al"); }
                else if (is_gt == 1) { Codegen.emit_line(self, "    setg %al"); }
                else if (is_le == 1) { Codegen.emit_line(self, "    setle %al"); }
                else if (is_ge == 1) { Codegen.emit_line(self, "    setge %al"); }
                Codegen.emit_line(self, "    movzbl %al, %eax");
            }
            ty is TY_INT;
        }
        return ty;
    }

    func int parse_add(int* self, int* pos) {
        ty is Codegen.parse_mul(self, pos);
        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
               (Codegen.tok_punct1(self, *pos, 43) == 1 || Codegen.tok_punct1(self, *pos, 45) == 1)) {
            op_pos is *pos;
            is_minus is Codegen.tok_punct1(self, *pos, 45);
            *pos is *pos + 1;
            if (is_minus == 1) {
                if (ty != TY_INT) { Codegen.error_at(self, "add expects int", op_pos); }
            }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_mul(self, pos);
            if (is_minus == 1) {
                if (rty != TY_INT) { Codegen.error_at(self, "add expects int", op_pos); }
            }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
                if (is_minus == 1) {
                    Codegen.emit_line_bitness(self, "    movq %rax, %rcx", "    movl %eax, %ecx");
                    Codegen.emit_line_bitness(self, "    movq %r10, %rax", "    movl %ebx, %eax");
                    Codegen.emit_line_bitness(self, "    subq %rcx, %rax", "    subl %ecx, %eax");
                } else {
                    # int+int or ptr+int
                    Codegen.emit_line_bitness(self, "    addq %r10, %rax", "    addl %ebx, %eax");
                }
            }
            if (is_minus == 1) {
                ty is TY_INT;
            } else {
                if (ty == TY_INT && rty == TY_INT) { ty is TY_INT; }
                else if ((ty == TY_STRING && rty == TY_INT) || (ty == TY_INT && rty == TY_STRING)) {
                    ty is TY_STRING;
                }
                else if (ty == TY_STRING || rty == TY_STRING) {
                    Codegen.error_at(self, "string concatenation is not supported yet", op_pos);
                } else {
                    Codegen.error_at(self, "add expects int", op_pos);
                }
            }
        }
        return ty;
    }

    func int parse_mul(int* self, int* pos) {
        ty is Codegen.parse_unary(self, pos);
        while (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
               (Codegen.tok_punct1(self, *pos, 42) == 1 || Codegen.tok_punct1(self, *pos, 47) == 1 || Codegen.tok_punct1(self, *pos, 37) == 1)) {
            op_div is Codegen.tok_punct1(self, *pos, 47);
            op_mod is Codegen.tok_punct1(self, *pos, 37);
            *pos is *pos + 1;
            if (ty != TY_INT) { cg_error("mul expects int"); }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
            rty is Codegen.parse_unary(self, pos);
            if (rty != TY_INT) { cg_error("mul expects int"); }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
                if (op_div == 1 || op_mod == 1) {
                    Codegen.emit_line_bitness(self, "    movq %rax, %rcx", "    movl %eax, %ecx");
                    Codegen.emit_line_bitness(self, "    movq %r10, %rax", "    movl %ebx, %eax");
                    Codegen.emit_line_bitness(self, "    cqo", "    cdq");
                    Codegen.emit_line_bitness(self, "    idivq %rcx", "    idivl %ecx");
                    if (op_mod == 1) { Codegen.emit_line_bitness(self, "    movq %rdx, %rax", "    movl %edx, %eax"); }
                } else {
                    Codegen.emit_line_bitness(self, "    imulq %r10, %rax", "    imull %ebx, %eax");
                }
            }
            ty is TY_INT;
        }
        return ty;
    }

    func int parse_unary(int* self, int* pos) {
	        if (Codegen.tok_punct1(self, *pos, 33) == 1) {
            # logical not: !expr (int-only, returns 0/1)
            op_pos is *pos;
            *pos is *pos + 1;
            ty is Codegen.parse_unary(self, pos);
	            if (ty != TY_INT) { Codegen.error_at(self, "unary ! expects int", op_pos); }
	            if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
	                Codegen.emit_line(self, "    sete %al");
	                Codegen.emit_line(self, "    movzbl %al, %eax");
	            }
	            return TY_INT;
	        }
        if (Codegen.tok_punct1(self, *pos, 38) == 1) {
            # address-of: &ident
            *pos is *pos + 1;
            if (VecToken.get_kind(self->toks, *pos) != TK_IDENT) { cg_error("expected identifier after '&'"); }
            ns is VecToken.get_start(self->toks, *pos);
            nl is VecToken.get_len(self->toks, *pos);
            vidx is Codegen.vars_find(self, ns, nl);
            if (vidx < 0) { Codegen.error_at(self, "unknown variable", *pos); }
            if (self->emit == 1) {
                off is Codegen.vars_get_off(self, vidx);
                if (self->bitness == 32) {
                    Codegen.emit_str(self, "    leal -");
                    Codegen.emit_dec(self, off);
                    Codegen.emit_line(self, "(%ebp), %eax");
                } else {
                    Codegen.emit_str(self, "    leaq -");
                    Codegen.emit_dec(self, off);
                    Codegen.emit_line(self, "(%rbp), %rax");
                }
            }
            *pos is *pos + 1;
            return TY_INT;
        }
        if (Codegen.tok_punct1(self, *pos, 42) == 1) {
            # deref: *expr (treat pointers as int addresses)
            *pos is *pos + 1;
            ty is Codegen.parse_unary(self, pos);
            if (ty != TY_INT) { cg_error("deref expects int"); }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    movq (%rax), %rax", "    movl (%eax), %eax"); }
            return TY_INT;
        }
        if (Codegen.tok_punct1(self, *pos, 45) == 1) {
            *pos is *pos + 1;
            ty is Codegen.parse_unary(self, pos);
            if (ty != TY_INT) { cg_error("unary - expects int"); }
            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    negq %rax", "    negl %eax"); }
            return TY_INT;
        }
        # Handle prefix ++ and -- (as standalone statements: ++i / --i)
        if (Codegen.tok_punct2(self, *pos, 43, 43) == 1) {
            *pos is *pos + 1;
            # Parse the operand as unary again (so ++*p works)
            ty is Codegen.parse_unary(self, pos);
            if (ty != TY_INT) { cg_error("++ expects int"); }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    addq $1, %rax", "    addl $1, %eax");
            }
            return TY_INT;
        }
        if (Codegen.tok_punct2(self, *pos, 45, 45) == 1) {
            *pos is *pos + 1;
            ty is Codegen.parse_unary(self, pos);
            if (ty != TY_INT) { cg_error("-- expects int"); }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    subq $1, %rax", "    subl $1, %eax");
            }
            return TY_INT;
        }
        return Codegen.parse_primary(self, pos);
    }

    func int parse_primary(int* self, int* pos) {
        k is VecToken.get_kind(self->toks, *pos);
        if (k == TK_NUMBER) {
            start is VecToken.get_start(self->toks, *pos);
            ln is VecToken.get_len(self->toks, *pos);
            v is 0;
            if (ln >= 3 && Codegen.byte_at(self, start + 0) == 48 &&
                (Codegen.byte_at(self, start + 1) == 120 || Codegen.byte_at(self, start + 1) == 88)) {
                # hex: 0x...
                for (int i is 2; i < ln; i is i + 1) {
                    c is Codegen.byte_at(self, start + i);
                    if (c >= 48 && c <= 57) { v is v * 16 + (c - 48); }
                    else if (c >= 65 && c <= 70) { v is v * 16 + (c - 65 + 10); }
                    else if (c >= 97 && c <= 102) { v is v * 16 + (c - 97 + 10); }
                }
            } else {
                for (int i is 0; i < ln; i is i + 1) { v is v * 10 + (Codegen.byte_at(self, start + i) - 48); }
            }
            if (self->emit == 1) {
                if (self->bitness == 32) { Codegen.emit_line_num(self, "    movl $", v, ", %eax"); }
                else { Codegen.emit_line_num(self, "    movq $", v, ", %rax"); }
            }
            *pos is *pos + 1;
            # Support float-ish literals like 123.45 as NUMBER '.' NUMBER (truncate).
            if (*pos + 1 < self->tok_count &&
                VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
                Codegen.tok_punct1(self, *pos, 46) == 1 &&
                VecToken.get_kind(self->toks, *pos + 1) == TK_NUMBER) {
                *pos is *pos + 2;
            }
            return TY_INT;
        }
        if (k == TK_STRING) {
            start is VecToken.get_start(self->toks, *pos);
            ln is VecToken.get_len(self->toks, *pos);
            sstart is start + 1;
            slen is ln - 2;
            idx is Codegen.strtab_intern(self, sstart, slen);
            if (self->emit == 1) {
                if (self->bitness == 32) {
                    Codegen.emit_str(self, "    movl $");
                    Codegen.emit_label_num(self, "str_", idx);
                    Codegen.emit_line(self, ", %eax");
                } else {
                    Codegen.emit_str(self, "    leaq ");
                    Codegen.emit_label_num(self, "str_", idx);
                    Codegen.emit_line(self, "(%rip), %rax");
                }
            }
            *pos is *pos + 1;
            return TY_STRING;
        }
        if (k == TK_CHAR_LITERAL) {
            # Char literal: extract the character value from the source
            start is VecToken.get_start(self->toks, *pos);
            ln is VecToken.get_len(self->toks, *pos);
            # Format: 'x' or '\n' etc. - extract the inner character
            inner_start is start + 1;
            inner_len is ln - 2;
            cval is 0;
            if (inner_len == 1) {
                cval is Codegen.byte_at(self, inner_start);
            } else if (inner_len == 2 && Codegen.byte_at(self, inner_start) == 92) {
                esc is Codegen.byte_at(self, inner_start + 1);
                if (esc == 110) { cval is 10; }
                else if (esc == 116) { cval is 9; }
                else if (esc == 48) { cval is 0; }
                else if (esc == 92) { cval is 92; }
                else if (esc == 39) { cval is 39; }
                else if (esc == 34) { cval is 34; }
                else { cval is esc; }
            }
            if (self->emit == 1) {
                if (self->bitness == 32) { Codegen.emit_line_num(self, "    movl $", cval, ", %eax"); }
                else { Codegen.emit_line_num(self, "    movq $", cval, ", %rax"); }
            }
            *pos is *pos + 1;
            return TY_INT;
        }
        if (k == TK_IDENT) {
            if (Codegen.tok_is_true(self, *pos) == 1) {
                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    movq $1, %rax", "    movl $1, %eax"); }
                *pos is *pos + 1;
                return TY_INT;
            }
            if (Codegen.tok_is_false(self, *pos) == 1) {
                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    xorq %rax, %rax", "    xorl %eax, %eax"); }
                *pos is *pos + 1;
                return TY_INT;
            }
            if (Codegen.tok_is_nullptr(self, *pos) == 1) {
                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    xorq %rax, %rax", "    xorl %eax, %eax"); }
                *pos is *pos + 1;
                return TY_INT;
            }

            base_name_start is VecToken.get_start(self->toks, *pos);
            base_name_len is VecToken.get_len(self->toks, *pos);
            class_idx is Codegen.class_find_by_name(self, base_name_start, base_name_len);
            base_ty is 0;

            # Class constructor: ClassName()
            if (class_idx >= 0 && *pos + 1 < self->tok_count &&
                VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
                Codegen.tok_punct1(self, *pos + 1, 40) == 1) {
                *pos is *pos + 2; # ident + '('
                if (*pos >= self->tok_count) { cg_error("unexpected end in constructor"); }
                if (Codegen.tok_punct1(self, *pos, 41) == 0) { cg_error("class constructor args not supported"); }
                *pos is *pos + 1;
                if (self->emit == 1) {
                    Codegen.emit_str(self, "    call __zn_new_");
                    file_write(self->fd, self->src + base_name_start, base_name_len);
                    Codegen.emit_nl(self);
                }
                base_ty is TY_CLASS_BASE + class_idx;
            }
            else if (VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
                     Codegen.tok_punct1(self, *pos + 1, 46) == 1 &&
                     Codegen.enum_find_by_name(self, base_name_start, base_name_len) >= 0 &&
                     *pos + 2 < self->tok_count &&
                     VecToken.get_kind(self->toks, *pos + 2) == TK_IDENT) {
                enum_idx is Codegen.enum_find_by_name(self, base_name_start, base_name_len);
                var_start is VecToken.get_start(self->toks, *pos + 2);
                var_len is VecToken.get_len(self->toks, *pos + 2);
                enum_val is Codegen.enum_variant_find_value(self, enum_idx, var_start, var_len);
                if (enum_val >= 0) {
                    if (self->emit == 1) {
                        if (self->bitness == 32) { Codegen.emit_line_num(self, "    movl $", enum_val, ", %eax"); }
                        else { Codegen.emit_line_num(self, "    movq $", enum_val, ", %rax"); }
                    }
                    *pos is *pos + 3;
                    base_ty is TY_ENUM_BASE + enum_idx;
                }
            }
            # Plain function call: ident(...)
	            else if (*pos + 1 < self->tok_count &&
	                     VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
	                     Codegen.tok_punct1(self, *pos + 1, 40) == 1) {
	                is_txtin is Codegen.tok_is_txtin(self, *pos);
	                name_start is base_name_start;
	                name_len is base_name_len;
	                is_copy is (name_len == 4 &&
	                           Codegen.byte_at(self, name_start + 0) == 99 &&
	                           Codegen.byte_at(self, name_start + 1) == 111 &&
	                           Codegen.byte_at(self, name_start + 2) == 112 &&
	                           Codegen.byte_at(self, name_start + 3) == 121);
	                method_fn_i is -1;
	                is_implicit_method is 0;
	                if (self->cur_self_off != 0 && self->cur_fn_class_idx >= 0) {
	                    method_fn_i is Codegen.method_find_func(self, self->cur_fn_class_idx, name_start, name_len);
	                    if (method_fn_i >= 0 && VecInt.get(self->fns, method_fn_i * 12 + 11) == 1) { is_implicit_method is 1; }
	                }
	                *pos is *pos + 2; # ident + '('
	                if (*pos >= self->tok_count) { cg_error("unexpected end in call"); }

	                argc is 0;
	                first_arg_ty is 0;
		                if (is_implicit_method == 1) {
		                    if (self->cur_self_off == 0) { cg_error("implicit method call missing self"); }
		                    if (self->emit == 1) {
		                        if (self->bitness == 32) { Codegen.emit_str(self, "    movl -"); }
		                        else { Codegen.emit_str(self, "    movq -"); }
		                        Codegen.emit_dec(self, self->cur_self_off);
		                        if (self->bitness == 32) {
		                            Codegen.emit_line(self, "(%ebp), %eax");
		                            Codegen.emit_line(self, "    pushl %eax");
		                        } else {
		                            Codegen.emit_line(self, "(%rbp), %rax");
		                            Codegen.emit_line(self, "    pushq %rax");
		                        }
		                    }
		                    argc is 1;
		                }
	                if (Codegen.tok_punct1(self, *pos, 41) == 0) {
	                    while (1) {
	                        aty is Codegen.parse_expr(self, pos);
	                        if (argc == 0) { first_arg_ty is aty; }
		                        if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
		                        argc is argc + 1;
	                        if (Codegen.tok_punct1(self, *pos, 44) == 1) { *pos is *pos + 1; continue; }
	                        break;
	                    }
	                }
                if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
                *pos is *pos + 1;

		                if (argc > 6) { cg_error("calls > 6 args not supported"); }

		                if (self->emit == 1) {
		                    if (self->bitness == 32) { Codegen.emit_call_prep(self, argc); }
		                    if (self->bitness == 64) {
		                        for (int ai is argc - 1; ai >= 0; ai is ai - 1) {
		                            if (ai == 0) { Codegen.emit_line(self, "    popq %rdi"); }
		                            else if (ai == 1) { Codegen.emit_line(self, "    popq %rsi"); }
		                            else if (ai == 2) { Codegen.emit_line(self, "    popq %rdx"); }
		                            else if (ai == 3) { Codegen.emit_line(self, "    popq %rcx"); }
		                            else if (ai == 4) { Codegen.emit_line(self, "    popq %r8"); }
		                            else if (ai == 5) { Codegen.emit_line(self, "    popq %r9"); }
		                        }
		                    }

		                    Codegen.emit_str(self, "    call ");
		                    if (is_implicit_method == 1) {
		                        Codegen.emit_fn_symbol(self, method_fn_i);
		                    } else if (is_copy == 1) {
	                        if (argc != 1) { cg_error("copy() expects 1 arg"); }
	                        cls is class_idx_from_ty(first_arg_ty);
	                        if (cls < 0) { cg_error("copy() expects class ptr"); }
	                        Codegen.emit_str(self, "__zn_copy_");
	                        file_write(self->fd,
	                                   self->src + Codegen.classes_get_name_start(self, cls),
	                                   Codegen.classes_get_name_len(self, cls));
		                    } else {
		                        file_write(self->fd, self->src + name_start, name_len);
		                    }
		                    Codegen.emit_nl(self);
		                    if (self->bitness == 32) { Codegen.emit_call_cleanup(self, argc); }
		                }

	                if (is_implicit_method == 1) { base_ty is VecInt.get(self->fns, method_fn_i * 12 + 6); }
	                else if (is_copy == 1) { base_ty is first_arg_ty; }
	                else if (is_txtin == 1) { base_ty is TY_STRING; }
	                else { base_ty is Codegen.fn_ret_ty_plain(self, name_start, name_len); }
	            }
            # Variable or class reference (for `Class.method()`).
            else {
                if (class_idx >= 0) {
                    *pos is *pos + 1;
                    base_ty is TY_CLASSREF_BASE + class_idx;
                } else {
                    ns is base_name_start;
                    nl is base_name_len;
            vidx is Codegen.vars_find(self, ns, nl);
            if (vidx < 0) {
                gidx is Codegen.globals_find(self, ns, nl);
                if (gidx < 0) { Codegen.error_at(self, "unknown variable", *pos); }
                gty is Codegen.globals_get_type(self, gidx);
                gval is Codegen.globals_get_val(self, gidx);
	                        if (self->emit == 1) {
	                            if (gty == TY_STRING) {
	                                if (self->bitness == 32) {
	                                    Codegen.emit_str(self, "    movl $");
	                                    Codegen.emit_label_num(self, "str_", gval);
	                                    Codegen.emit_line(self, ", %eax");
	                                } else {
	                                    Codegen.emit_str(self, "    leaq ");
	                                    Codegen.emit_label_num(self, "str_", gval);
	                                    Codegen.emit_line(self, "(%rip), %rax");
	                                }
	                            } else {
	                                if (self->bitness == 32) { Codegen.emit_line_num(self, "    movl $", gval, ", %eax"); }
	                                else { Codegen.emit_line_num(self, "    movq $", gval, ", %rax"); }
	                            }
	                        }
                        *pos is *pos + 1;
                        base_ty is gty;
                    } else {
	                        base_ty is Codegen.vars_get_type(self, vidx);
	                        if (self->cur_assign_check_self == 1 &&
	                            Codegen.name_matches(self, ns, nl, self->cur_assign_name_start, self->cur_assign_name_len) == 1) {
	                            self->cur_assign_self_ref is 1;
	                        }
	                        if (self->emit == 1) {
	                            off is Codegen.vars_get_off(self, vidx);
	                            if (self->bitness == 32) {
	                                Codegen.emit_str(self, "    movl -");
	                                Codegen.emit_dec(self, off);
	                                Codegen.emit_line(self, "(%ebp), %eax");
	                            } else {
	                                Codegen.emit_str(self, "    movq -");
	                                Codegen.emit_dec(self, off);
	                                Codegen.emit_line(self, "(%rbp), %rax");
	                            }
	                        }
                        *pos is *pos + 1;
                    }
                }
            }

            # Postfix: member access / calls / array access
            while (1) {
                if (*pos >= self->tok_count) { break; }
                # member access: '.' or '->'
                if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
                    (Codegen.tok_punct1(self, *pos, 46) == 1 || Codegen.tok_punct2(self, *pos, 45, 62) == 1)) {
                    *pos is *pos + 1;
                    if (*pos >= self->tok_count) { cg_error("unexpected end after member op"); }
                    if (VecToken.get_kind(self->toks, *pos) != TK_IDENT) { cg_error("expected member name"); }
                    mpos is *pos;
                    mstart is VecToken.get_start(self->toks, *pos);
                    mlen is VecToken.get_len(self->toks, *pos);
                    *pos is *pos + 1;

                    cls is class_idx_from_ty(base_ty);
                    if (cls < 0) { cg_error("member access on non-object"); }

                    # Method call: (...).
                    if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 40) == 1) {
                        fn_i is Codegen.method_find_func(self, cls, mstart, mlen);
                        if (fn_i < 0) { cg_error("unknown method"); }
                        is_instance is VecInt.get(self->fns, fn_i * 12 + 11);

                        *pos is *pos + 1; # '('
                        argc is 0;
                        # If this is an instance method called on an object (`obj.method()`),
                        # implicitly pass `obj` as the first argument. If called via class
                        # (`Class.method(obj, ...)`), the caller must provide `self` explicitly.
	                        if (is_instance == 1 && is_class_ref_ty(base_ty) == 0) {
	                            if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
	                            argc is argc + 1;
	                        }
                        if (Codegen.tok_punct1(self, *pos, 41) == 0) {
                            while (1) {
	                                Codegen.parse_expr(self, pos);
	                                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
	                                argc is argc + 1;
                                if (Codegen.tok_punct1(self, *pos, 44) == 1) { *pos is *pos + 1; continue; }
                                break;
                            }
                        }
                        if (is_instance == 1 && is_class_ref_ty(base_ty) == 1 && argc == 0) {
                            Codegen.error_at(self, "instance method requires explicit self arg", *pos);
                        }
                        if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
                        *pos is *pos + 1;

	                        if (argc > 6) { cg_error("calls > 6 args not supported"); }

	                        if (self->emit == 1) {
	                            if (self->bitness == 32) { Codegen.emit_call_prep(self, argc); }
	                            if (self->bitness == 64) {
	                                for (int ai is argc - 1; ai >= 0; ai is ai - 1) {
	                                    if (ai == 0) { Codegen.emit_line(self, "    popq %rdi"); }
	                                    else if (ai == 1) { Codegen.emit_line(self, "    popq %rsi"); }
	                                    else if (ai == 2) { Codegen.emit_line(self, "    popq %rdx"); }
	                                    else if (ai == 3) { Codegen.emit_line(self, "    popq %rcx"); }
	                                    else if (ai == 4) { Codegen.emit_line(self, "    popq %r8"); }
	                                    else if (ai == 5) { Codegen.emit_line(self, "    popq %r9"); }
	                                }
	                            }
	                            Codegen.emit_str(self, "    call ");
	                            Codegen.emit_fn_symbol(self, fn_i);
	                            Codegen.emit_nl(self);
	                            if (self->bitness == 32) { Codegen.emit_call_cleanup(self, argc); }
	                        }

                        base_ty is VecInt.get(self->fns, fn_i * 12 + 6);
                        continue;
                    }

                    # Field access: load *(base + off)
                    if (is_class_ref_ty(base_ty) == 1) { cg_error("field access on class"); }
                    off is Codegen.field_offset(self, cls, mstart, mlen);
	                    if (off < 0) { Codegen.error_at(self, "unknown field", mpos); }
	                    if (self->emit == 1) {
	                        if (self->bitness == 32) {
	                            Codegen.emit_str(self, "    movl ");
	                            Codegen.emit_dec(self, off);
	                            Codegen.emit_line(self, "(%eax), %eax");
	                        } else {
	                            Codegen.emit_str(self, "    movq ");
	                            Codegen.emit_dec(self, off);
	                            Codegen.emit_line(self, "(%rax), %rax");
	                        }
	                    }
                    base_ty is TY_INT;
                    continue;
                }

	                # array access: expr '[' idx ']'
		                if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 91) == 1) {
		                    *pos is *pos + 1;
		                    if (self->emit == 1) { Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax"); }
		                    ity is Codegen.parse_expr(self, pos);
	                    if (ity != TY_INT) { cg_error("index expects int"); }
	                    if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 93) == 0) { Codegen.error_at(self, "expected ']'", *pos); }
	                    *pos is *pos + 1;
		                    if (self->emit == 1) {
		                        Codegen.emit_line_bitness(self, "    movq %rax, %rcx", "    movl %eax, %ecx");
		                        Codegen.emit_line_bitness(self, "    popq %rax", "    popl %eax");
		                        if (base_ty == TY_STRING) {
		                            Codegen.emit_line_bitness(self, "    leaq (%rax,%rcx,1), %rax", "    leal (%eax,%ecx,1), %eax");
		                            Codegen.emit_line_bitness(self, "    movzbq (%rax), %rax", "    movzbl (%eax), %eax");
		                        } else {
		                            if (self->bitness == 32) {
		                                Codegen.emit_line(self, "    leal (%eax,%ecx,4), %eax");
		                                Codegen.emit_line(self, "    movl (%eax), %eax");
		                            } else {
		                                Codegen.emit_line(self, "    leaq (%rax,%rcx,8), %rax");
		                                Codegen.emit_line(self, "    movq (%rax), %rax");
		                            }
		                        }
		                    }
	                    if (base_ty == TY_STR_ARR) { base_ty is TY_STRING; }
	                    else { base_ty is TY_INT; }
	                    continue;
	                }

                # postfix ++ and --
                if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
                    (Codegen.tok_punct2(self, *pos, 43, 43) == 1 || Codegen.tok_punct2(self, *pos, 45, 45) == 1)) {
                    is_inc is Codegen.tok_punct2(self, *pos, 43, 43);
                    *pos is *pos + 1;
                    if (base_ty != TY_INT) { cg_error("++/-- expects int"); }
                    if (self->emit == 1) {
                        if (is_inc == 1) {
                            Codegen.emit_line_bitness(self, "    addq $1, %rax", "    addl $1, %eax");
                        } else {
                            Codegen.emit_line_bitness(self, "    subq $1, %rax", "    subl $1, %eax");
                        }
                    }
                    continue;
                }

                break;
            }

            return base_ty;
        }
        # Array literal: [size]{data}  (the {data} part is optional)
        if (k == TK_PUNCT && Codegen.tok_punct1(self, *pos, 91) == 1) {
            *pos is *pos + 1; # '['
            size_ty is Codegen.parse_expr(self, pos);
            if (size_ty != TY_INT) { cg_error("array size expects int"); }
            if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 93) == 0) { Codegen.error_at(self, "expected ']'", *pos); }
            *pos is *pos + 1; # ']'

            # Optional initializer block { e0, e1, ... }
            has_data is 0;
            if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 123) == 1) {
                has_data is 1;
                *pos is *pos + 1; # '{'
            }

            # Count elements (compile-time constant) so we can allocate max(size, count).
            elem_count is 0;
            if (has_data == 1) {
                save_emit is self->emit;
                self->emit is 0;
                cpos is *pos;
                while (1) {
                    if (VecToken.get_kind(self->toks, cpos) == TK_PUNCT && Codegen.tok_punct1(self, cpos, 125) == 1) { break; }
                    Codegen.parse_expr(self, &cpos);
                    elem_count is elem_count + 1;
                    if (VecToken.get_kind(self->toks, cpos) == TK_PUNCT && Codegen.tok_punct1(self, cpos, 44) == 1) { cpos is cpos + 1; continue; }
                    break;
                }
                self->emit is save_emit;
            }

            if (self->emit == 1) {
                # rax = size; allocate max(size, elem_count) * word_size bytes.
                # cmov is register-to-register only (no immediate operands).
                if (self->bitness == 32) {
                    if (elem_count > 0) {
                        Codegen.emit_line(self, "    movl %eax, %edi");
                        Codegen.emit_line_num(self, "    movl $", elem_count, ", %ecx");
                        Codegen.emit_line(self, "    cmpl %ecx, %eax");
                        Codegen.emit_line(self, "    cmovl %ecx, %edi");
                        Codegen.emit_line(self, "    imull $4, %edi");
                    } else {
                        Codegen.emit_line(self, "    imull $4, %eax");
                        Codegen.emit_line(self, "    movl %eax, %edi");
                    }
                    Codegen.emit_call_prep(self, 1);
                    Codegen.emit_line(self, "    pushl %edi");
                    Codegen.emit_line(self, "    call malloc@PLT");
                    Codegen.emit_call_cleanup(self, 1);
                    Codegen.emit_line(self, "    pushl %eax"); # save base
                } else {
                    if (elem_count > 0) {
                        Codegen.emit_line(self, "    movq %rax, %rdi");
                        Codegen.emit_line_num(self, "    movq $", elem_count, ", %rdx");
                        Codegen.emit_line(self, "    cmpq %rdx, %rax");
                        Codegen.emit_line(self, "    cmovlq %rdx, %rdi");
                        Codegen.emit_line(self, "    imulq $8, %rdi");
                    } else {
                        Codegen.emit_line(self, "    imulq $8, %rax");
                        Codegen.emit_line(self, "    movq %rax, %rdi");
                    }
                    Codegen.emit_line(self, "    call malloc@PLT");
                    Codegen.emit_line(self, "    pushq %rax"); # save base
                }
            }

            elem_idx is 0;
            if (has_data == 1) {
                while (1) {
                    ety is Codegen.parse_expr(self, pos);
                    if (ety != TY_INT) { cg_error("array element expects int"); }
                    if (self->emit == 1) {
                        if (self->bitness == 32) {
                            Codegen.emit_line(self, "    popl %ebx"); # base
                            Codegen.emit_str(self, "    movl %eax, ");
                            Codegen.emit_dec(self, elem_idx * 4);
                            Codegen.emit_line(self, "(%ebx)");
                            Codegen.emit_line(self, "    pushl %ebx"); # restore base
                        } else {
                            Codegen.emit_line(self, "    popq %r10"); # base
                            Codegen.emit_str(self, "    movq %rax, ");
                            Codegen.emit_dec(self, elem_idx * 8);
                            Codegen.emit_line(self, "(%r10)");
                            Codegen.emit_line(self, "    pushq %r10"); # restore base
                        }
                    }
                    elem_idx is elem_idx + 1;
                    if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 44) == 1) {
                        *pos is *pos + 1;
                        continue;
                    }
                    break;
                }
                if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 125) == 0) { Codegen.error_at(self, "expected '}'", *pos); }
                *pos is *pos + 1; # '}'
            }

            if (self->emit == 1) {
                if (self->bitness == 32) { Codegen.emit_line(self, "    popl %eax"); } # base as result
                else { Codegen.emit_line(self, "    popq %rax"); } # base as result
            }
            return TY_ARRAY;
        }

        if (k == TK_PUNCT && Codegen.tok_punct1(self, *pos, 40) == 1) {
            *pos is *pos + 1;
            ty is Codegen.parse_expr(self, pos);
            if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
            *pos is *pos + 1;
            return ty;
        }
        Codegen.error_at(self, "unexpected token in expression", *pos);
        return TY_INT;
    }

	    func void emit_runtime_helpers(int* self) {
	        Codegen.emit_line(self, ".globl __zinc_rt_exit");
	        Codegen.emit_line(self, ".globl __zinc_rt_free");
	        Codegen.emit_line(self, ".globl __zinc_rt_malloc");
        Codegen.emit_line(self, ".globl __zinc_rt_memset");
        Codegen.emit_line(self, ".globl __zinc_rt_memcpy");
        Codegen.emit_line(self, ".globl __zinc_rt_strcmp");
        Codegen.emit_line(self, ".globl __zinc_rt_strdup");
        Codegen.emit_line(self, ".globl __zinc_rt_printf");
        Codegen.emit_line(self, ".globl __zinc_rt_fgets");
	        Codegen.emit_line(self, ".globl __zinc_rt_strlen");
	        Codegen.emit_line(self, ".globl txtin");
	        Codegen.emit_line(self, "");

	        if (self->bitness == 32) {
	            Codegen.emit_line(self, "__zinc_rt_exit:");
	            Codegen.emit_line(self, "    pushl %ebp");
	            Codegen.emit_line(self, "    movl %esp, %ebp");
	            Codegen.emit_call_prep(self, 1);
	            Codegen.emit_line(self, "    pushl $0");
	            Codegen.emit_line(self, "    call fflush@PLT");
	            Codegen.emit_call_cleanup(self, 1);
	            Codegen.emit_call_prep(self, 1);
	            Codegen.emit_line(self, "    pushl 8(%ebp)");
	            Codegen.emit_line(self, "    call _exit@PLT");
	            Codegen.emit_call_cleanup(self, 1);
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_free:");
	            Codegen.emit_line(self, "    jmp free@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_malloc:");
	            Codegen.emit_line(self, "    jmp malloc@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_memset:");
	            Codegen.emit_line(self, "    jmp memset@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_memcpy:");
	            Codegen.emit_line(self, "    jmp memcpy@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_strcmp:");
	            Codegen.emit_line(self, "    jmp strcmp@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_strdup:");
	            Codegen.emit_line(self, "    jmp strdup@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_printf:");
	            Codegen.emit_line(self, "    jmp printf@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_fgets:");
	            Codegen.emit_line(self, "    jmp fgets@PLT");
	            Codegen.emit_line(self, "");

	            Codegen.emit_line(self, "__zinc_rt_strlen:");
	            Codegen.emit_line(self, "    jmp strlen@PLT");
	            Codegen.emit_line(self, "");

	            # txtin(): minimal stub (returns empty malloc'd string).
	            Codegen.emit_line(self, "txtin:");
	            Codegen.emit_line(self, "    pushl %ebp");
	            Codegen.emit_line(self, "    movl %esp, %ebp");
	            Codegen.emit_call_prep(self, 1);
	            Codegen.emit_line(self, "    pushl $1");
	            Codegen.emit_line(self, "    call malloc@PLT");
	            Codegen.emit_call_cleanup(self, 1);
	            Codegen.emit_line(self, "    testl %eax, %eax");
	            Codegen.emit_line(self, "    je .Ltxtin32_ret0");
	            Codegen.emit_line(self, "    movb $0, (%eax)");
	            Codegen.emit_line(self, "    jmp .Ltxtin32_done");
	            Codegen.emit_line(self, ".Ltxtin32_ret0:");
	            Codegen.emit_line(self, "    xorl %eax, %eax");
	            Codegen.emit_line(self, ".Ltxtin32_done:");
	            Codegen.emit_line(self, "    movl %ebp, %esp");
	            Codegen.emit_line(self, "    popl %ebp");
	            Codegen.emit_line(self, "    ret");
	            Codegen.emit_line(self, "");
	            return;
	        }

	        Codegen.emit_line(self, "__zinc_rt_exit:");
	        Codegen.emit_line(self, "    pushq %rbp");
	        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    movq %rdi, %rbx");
        Codegen.emit_line(self, "    xorq %rdi, %rdi");
        Codegen.emit_line(self, "    call fflush@PLT");
        Codegen.emit_line(self, "    movq %rbx, %rdi");
        Codegen.emit_line(self, "    call _exit@PLT");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_free:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call free@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_malloc:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call malloc@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_memset:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call memset@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_memcpy:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call memcpy@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_strcmp:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call strcmp@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_strdup:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call strdup@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_printf:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call printf@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_fgets:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call fgets@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        Codegen.emit_line(self, "__zinc_rt_strlen:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    call strlen@PLT");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");

        # txtin(): read up to 1023 bytes from stdin (fd=0) and return a
        # NUL-terminated heap string (malloc'd). Best-effort: returns empty
        # string on EOF/error.
        Codegen.emit_line(self, "txtin:");
        Codegen.emit_line(self, "    pushq %rbp");
        Codegen.emit_line(self, "    movq %rsp, %rbp");
        Codegen.emit_line(self, "    pushq %rbx");
        Codegen.emit_line(self, "    movl $1024, %edi");
        Codegen.emit_line(self, "    call malloc@PLT");
        Codegen.emit_line(self, "    movq %rax, %rbx");
        Codegen.emit_line(self, "    testq %rbx, %rbx");
        Codegen.emit_line(self, "    je .Ltxtin_ret0");
        Codegen.emit_line(self, "    xorl %edi, %edi");
        Codegen.emit_line(self, "    movq %rbx, %rsi");
        Codegen.emit_line(self, "    movl $1023, %edx");
        Codegen.emit_line(self, "    call read@PLT");
        Codegen.emit_line(self, "    cmpq $0, %rax");
        Codegen.emit_line(self, "    jg .Ltxtin_got");
        Codegen.emit_line(self, "    movb $0, (%rbx)");
        Codegen.emit_line(self, "    movq %rbx, %rax");
        Codegen.emit_line(self, "    jmp .Ltxtin_done");
        Codegen.emit_line(self, ".Ltxtin_got:");
        Codegen.emit_line(self, "    movq %rax, %rcx");
        Codegen.emit_line(self, "    movb $0, (%rbx,%rcx,1)");
        Codegen.emit_line(self, "    decq %rcx");
        Codegen.emit_line(self, "    js .Ltxtin_ok");
        Codegen.emit_line(self, "    movb (%rbx,%rcx,1), %al");
        Codegen.emit_line(self, "    cmpb $10, %al");
        Codegen.emit_line(self, "    je .Ltxtin_strip");
        Codegen.emit_line(self, "    cmpb $13, %al");
        Codegen.emit_line(self, "    jne .Ltxtin_ok");
        Codegen.emit_line(self, ".Ltxtin_strip:");
        Codegen.emit_line(self, "    movb $0, (%rbx,%rcx,1)");
        Codegen.emit_line(self, ".Ltxtin_ok:");
        Codegen.emit_line(self, "    movq %rbx, %rax");
        Codegen.emit_line(self, "    jmp .Ltxtin_done");
        Codegen.emit_line(self, ".Ltxtin_ret0:");
        Codegen.emit_line(self, "    xorq %rax, %rax");
        Codegen.emit_line(self, ".Ltxtin_done:");
        Codegen.emit_line(self, "    popq %rbx");
        Codegen.emit_line(self, "    movq %rbp, %rsp");
        Codegen.emit_line(self, "    popq %rbp");
        Codegen.emit_line(self, "    retq");
        Codegen.emit_line(self, "");
    }

	    func void emit_class_helpers(int* self) {
	        nc is Codegen.classes_count(self);
	        for (int ci is 0; ci < nc; ci is ci + 1) {
            cname_start is Codegen.classes_get_name_start(self, ci);
            cname_len is Codegen.classes_get_name_len(self, ci);
            sz is Codegen.classes_get_size(self, ci);

            Codegen.emit_line(self, "");
            Codegen.emit_str(self, ".globl __zn_new_");
            file_write(self->fd, self->src + cname_start, cname_len);
            Codegen.emit_nl(self);
            Codegen.emit_str(self, ".globl __zn_copy_");
            file_write(self->fd, self->src + cname_start, cname_len);
            Codegen.emit_nl(self);

	            # __zn_new_Class:
	            Codegen.emit_str(self, "__zn_new_");
	            file_write(self->fd, self->src + cname_start, cname_len);
	            Codegen.emit_line(self, ":");
	            if (self->bitness == 32) {
	                Codegen.emit_line(self, "    pushl %ebp");
	                Codegen.emit_line(self, "    movl %esp, %ebp");
	                Codegen.emit_call_prep(self, 1);
	                Codegen.emit_str(self, "    pushl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_nl(self);
	                Codegen.emit_line(self, "    call malloc@PLT");
	                Codegen.emit_call_cleanup(self, 1);
	
	                Codegen.emit_call_prep(self, 3);
	                Codegen.emit_str(self, "    pushl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_nl(self);
	                Codegen.emit_line(self, "    pushl $0");
	                Codegen.emit_line(self, "    pushl %eax");
	                Codegen.emit_line(self, "    call memset@PLT");
	                Codegen.emit_call_cleanup(self, 3);
	
	                Codegen.emit_line(self, "    movl %ebp, %esp");
	                Codegen.emit_line(self, "    popl %ebp");
	                Codegen.emit_line(self, "    ret");
	            } else {
	                Codegen.emit_line(self, "    pushq %rbp");
	                Codegen.emit_line(self, "    movq %rsp, %rbp");
	                Codegen.emit_str(self, "    movl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_line(self, ", %edi");
	                Codegen.emit_line(self, "    call malloc@PLT");
	                Codegen.emit_line(self, "    movq %rax, %rdi");
	                Codegen.emit_line(self, "    xorl %esi, %esi");
	                Codegen.emit_str(self, "    movl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_line(self, ", %edx");
	                Codegen.emit_line(self, "    call memset@PLT");
	                # memset returns the destination pointer in %rax
	                Codegen.emit_line(self, "    movq %rbp, %rsp");
	                Codegen.emit_line(self, "    popq %rbp");
	                Codegen.emit_line(self, "    retq");
	            }

	            # __zn_copy_Class(src): returns new copy
	            Codegen.emit_str(self, "__zn_copy_");
	            file_write(self->fd, self->src + cname_start, cname_len);
	            Codegen.emit_line(self, ":");
	            if (self->bitness == 32) {
	                Codegen.emit_line(self, "    pushl %ebp");
	                Codegen.emit_line(self, "    movl %esp, %ebp");
	                Codegen.emit_line(self, "    pushl %ebx");
	                Codegen.emit_line(self, "    movl 8(%ebp), %ebx");
	
	                Codegen.emit_call_prep(self, 1);
	                Codegen.emit_str(self, "    pushl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_nl(self);
	                Codegen.emit_line(self, "    call malloc@PLT");
	                Codegen.emit_call_cleanup(self, 1);
	
	                Codegen.emit_call_prep(self, 3);
	                Codegen.emit_str(self, "    pushl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_nl(self);
	                Codegen.emit_line(self, "    pushl %ebx");
	                Codegen.emit_line(self, "    pushl %eax");
	                Codegen.emit_line(self, "    call memcpy@PLT");
	                Codegen.emit_call_cleanup(self, 3);
	
	                Codegen.emit_line(self, "    popl %ebx");
	                Codegen.emit_line(self, "    movl %ebp, %esp");
	                Codegen.emit_line(self, "    popl %ebp");
	                Codegen.emit_line(self, "    ret");
	            } else {
	                Codegen.emit_line(self, "    pushq %rbp");
	                Codegen.emit_line(self, "    movq %rsp, %rbp");
	                Codegen.emit_line(self, "    pushq %rbx");
	                Codegen.emit_line(self, "    movq %rdi, %rbx");
	                Codegen.emit_str(self, "    movl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_line(self, ", %edi");
	                Codegen.emit_line(self, "    call malloc@PLT");
	                Codegen.emit_line(self, "    movq %rax, %rdi");
	                Codegen.emit_line(self, "    movq %rbx, %rsi");
	                Codegen.emit_str(self, "    movl $");
	                Codegen.emit_dec(self, sz);
	                Codegen.emit_line(self, ", %edx");
	                Codegen.emit_line(self, "    call memcpy@PLT");
	                # memcpy returns the destination pointer in %rax
	                Codegen.emit_line(self, "    popq %rbx");
	                Codegen.emit_line(self, "    movq %rbp, %rsp");
	                Codegen.emit_line(self, "    popq %rbp");
	                Codegen.emit_line(self, "    retq");
	            }
	        }
	    }

    func int new_label(int* self) {
        id is self->label_counter;
        self->label_counter is self->label_counter + 1;
        return id;
    }

    func void emit_label(int* self, int id) {
        Codegen.emit_str(self, ".L");
        Codegen.emit_dec(self, id);
        Codegen.emit_line(self, ":");
    }

    func void emit_fn_symbol(int* self, int fn_idx) {
        if (self->fns == 0) { cg_error("internal: missing fn table"); }
        kind is VecInt.get(self->fns, fn_idx * 12 + 0);
        if (kind == 0) {
            name_start is VecInt.get(self->fns, fn_idx * 12 + 4);
            name_len is VecInt.get(self->fns, fn_idx * 12 + 5);
            file_write(self->fd, self->src + name_start, name_len);
            return;
        }
        cname_start is VecInt.get(self->fns, fn_idx * 12 + 2);
        cname_len is VecInt.get(self->fns, fn_idx * 12 + 3);
        mname_start is VecInt.get(self->fns, fn_idx * 12 + 4);
        mname_len is VecInt.get(self->fns, fn_idx * 12 + 5);
        file_write(self->fd, self->src + cname_start, cname_len);
        Codegen.emit_str(self, "__");
        file_write(self->fd, self->src + mname_start, mname_len);
    }

    func void parse_block(int* self, int* pos, int* out_body_start, int* out_rbrace) {
        if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 123) == 0) { cg_error("expected '{'"); }
        *pos is *pos + 1;
        *out_body_start is *pos;

        depth is 1;
        while (*pos < self->tok_count && depth > 0) {
            if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT) {
                if (Codegen.tok_punct1(self, *pos, 123) == 1) { depth is depth + 1; }
                else if (Codegen.tok_punct1(self, *pos, 125) == 1) { depth is depth - 1; }
            }
            *pos is *pos + 1;
        }
        if (depth != 0) { cg_error("unterminated block"); }
        *out_rbrace is *pos - 1; # token index of '}'
    }

    func void parse_bind_assign(int* self, int* pos, int end_ch, int require_semicolon) {
        ty_decl is 0;
        ty_decl is Codegen.type_ty_at(self, *pos);
        if (ty_decl != 0) { *pos is *pos + 1; }

        # pointer stars after explicit type (e.g. `int* p is &x;`)
        while (ty_decl != 0 &&
               VecToken.get_kind(self->toks, *pos) == TK_PUNCT &&
               Codegen.tok_punct1(self, *pos, 42) == 1) {
            *pos is *pos + 1;
        }

        name_pos is *pos;
        if (VecToken.get_kind(self->toks, *pos) != TK_IDENT) { cg_error("expected variable name"); }
        ns is VecToken.get_start(self->toks, *pos);
        nl is VecToken.get_len(self->toks, *pos);
        *pos is *pos + 1;

        if (Codegen.tok_is_is(self, *pos) == 0) { cg_error("expected 'is'"); }
        *pos is *pos + 1;

        prev_assign_start is self->cur_assign_name_start;
        prev_assign_len is self->cur_assign_name_len;
        prev_assign_check is self->cur_assign_check_self;
        prev_assign_ref is self->cur_assign_self_ref;
        self->cur_assign_name_start is ns;
        self->cur_assign_name_len is nl;
        self->cur_assign_check_self is 1;
        self->cur_assign_self_ref is 0;

        expr_ty is Codegen.parse_expr(self, pos);

        if (require_semicolon == 1) {
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
        } else {
            if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, end_ch) == 0) { cg_error("expected end"); }
        }

        final_ty is expr_ty;
        if (ty_decl != 0) {
            if (expr_ty != ty_decl) {
                # Allow `int x is [n]{...}` to bind an int[] (array) variable.
                if (ty_decl == TY_INT && expr_ty == TY_ARRAY) {
                    final_ty is TY_ARRAY;
                } else {
                    cg_error("type mismatch");
                }
            } else {
                final_ty is ty_decl;
            }
        }

	        vidx is Codegen.vars_find(self, ns, nl);
	        if (vidx < 0) {
	            off is (Codegen.vars_count(self) + 1) * self->word_size;
	            mutable is 0;
	            if (ty_decl == 0) { mutable is 1; }
	            Codegen.vars_add(self, ns, nl, final_ty, off, mutable);
            vidx is Codegen.vars_find(self, ns, nl);
        } else {
            if (Codegen.vars_get_type(self, vidx) != final_ty) {
                if (Codegen.vars_get_mutable(self, vidx) == 1) {
                    if (self->cur_assign_self_ref == 1) {
                        Codegen.error_at(self, "self-referential polymorphic rebind is not supported yet", name_pos);
                    }
                    VecInt.set(self->vars, vidx * 5 + 2, final_ty);
                } else {
                    cg_error("rebind type mismatch");
                }
            }
        }

        self->cur_assign_name_start is prev_assign_start;
        self->cur_assign_name_len is prev_assign_len;
        self->cur_assign_check_self is prev_assign_check;
        self->cur_assign_self_ref is prev_assign_ref;

	        if (self->emit == 1) {
	            off is Codegen.vars_get_off(self, vidx);
	            if (self->bitness == 32) {
	                Codegen.emit_str(self, "    movl %eax, -");
	                Codegen.emit_dec(self, off);
	                Codegen.emit_line(self, "(%ebp)");
	            } else {
	                Codegen.emit_str(self, "    movq %rax, -");
	                Codegen.emit_dec(self, off);
	                Codegen.emit_line(self, "(%rbp)");
	            }
	        }
    }

    func void parse_stmt(int* self, int* pos, int end) {
        if (*pos >= end) { return; }
        if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 59) == 1) {
            *pos is *pos + 1;
            return;
        }
        # Array element assignment: arr[idx] is expr;
        if (*pos + 2 < end &&
            *pos + 2 < self->tok_count &&
            VecToken.get_kind(self->toks, *pos) == TK_IDENT &&
            VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
            Codegen.tok_punct1(self, *pos + 1, 91) == 1) {
            arr_start is VecToken.get_start(self->toks, *pos);
            arr_len is VecToken.get_len(self->toks, *pos);
            vidx is Codegen.vars_find(self, arr_start, arr_len);
            if (vidx < 0) { Codegen.error_at(self, "unknown array", *pos); }
            arr_ty is Codegen.vars_get_type(self, vidx);
            if (arr_ty != TY_ARRAY) { Codegen.error_at(self, "indexed assignment on non-array", *pos); }

            *pos is *pos + 2; # ident + '['
            ity is Codegen.parse_expr(self, pos);
            if (ity != TY_INT) { cg_error("index expects int"); }
            if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 93) == 0) { Codegen.error_at(self, "expected ']'", *pos); }
            *pos is *pos + 1; # ']'

            if (Codegen.tok_is_is(self, *pos) == 0) { cg_error("expected 'is'"); }
            *pos is *pos + 1;

            if (self->emit == 1) {
                if (self->bitness == 32) {
                    Codegen.emit_line(self, "    pushl %eax"); # index
                } else {
                    Codegen.emit_line(self, "    pushq %rax"); # index
                }
            }

            rhs_ty is Codegen.parse_expr(self, pos);
            if (rhs_ty != TY_INT) { cg_error("array element expects int"); }
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;

            if (self->emit == 1) {
                off is Codegen.vars_get_off(self, vidx);
                if (self->bitness == 32) {
                    Codegen.emit_line(self, "    popl %ecx"); # index
                    Codegen.emit_str(self, "    movl -");
                    Codegen.emit_dec(self, off);
                    Codegen.emit_line(self, "(%ebp), %ebx"); # base
                    Codegen.emit_str(self, "    movl %eax, ");
                    Codegen.emit_line(self, "(%ebx,%ecx,4)");
                } else {
                    Codegen.emit_line(self, "    popq %rcx"); # index
                    Codegen.emit_str(self, "    movq -");
                    Codegen.emit_dec(self, off);
                    Codegen.emit_line(self, "(%rbp), %r10"); # base
                    Codegen.emit_str(self, "    movq %rax, ");
                    Codegen.emit_line(self, "(%r10,%rcx,8)");
                }
            }
            return;
        }
        # Pointer store statement: `*p is expr;`
        if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 42) == 1) {
            *pos is *pos + 1;
            if (VecToken.get_kind(self->toks, *pos) != TK_IDENT) { cg_error("expected identifier after '*'"); }
            ns is VecToken.get_start(self->toks, *pos);
            nl is VecToken.get_len(self->toks, *pos);
            vidx is Codegen.vars_find(self, ns, nl);
            if (vidx < 0) { Codegen.error_at(self, "unknown variable", *pos); }

	            if (self->emit == 1) {
	                off is Codegen.vars_get_off(self, vidx);
	                if (self->bitness == 32) {
	                    Codegen.emit_str(self, "    movl -");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%ebp), %eax");
	                    Codegen.emit_line(self, "    pushl %eax");
	                } else {
	                    Codegen.emit_str(self, "    movq -");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%rbp), %rax");
	                    Codegen.emit_line(self, "    pushq %rax");
	                }
	            }
            *pos is *pos + 1;

            if (Codegen.tok_is_is(self, *pos) == 0) { cg_error("expected 'is'"); }
            *pos is *pos + 1;
            rhs_ty is Codegen.parse_expr(self, pos);
            if (rhs_ty == TY_VOID) { Codegen.error_at(self, "store expects value", *pos); }
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
	        if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    popq %r10", "    popl %ebx");
	                Codegen.emit_line_bitness(self, "    movq %rax, (%r10)", "    movl %eax, (%ebx)");
	        }
            return;
        }

        if (Codegen.tok_is_match_kw(self, *pos) == 1) {
            *pos is *pos + 1;
            scrut_ty is Codegen.parse_expr(self, pos);
            if (Codegen.tok_punct1(self, *pos, 123) == 0) { Codegen.error_at(self, "expected '{' after match", *pos); }
            *pos is *pos + 1;

            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    pushq %rax", "    pushl %eax");
            }

            end_lbl is Codegen.new_label(self);
            saw_default is 0;

            while (*pos < end && Codegen.tok_punct1(self, *pos, 125) == 0) {
                if (Codegen.tok_is_case_kw(self, *pos) == 1) {
                    case_next_lbl is Codegen.new_label(self);
                    *pos is *pos + 1;
                    case_ty is Codegen.parse_expr(self, pos);
                    if (types_match(scrut_ty, case_ty) == 0) { cg_error("match case type mismatch"); }
                    bstart is 0;
                    br is 0;
                    Codegen.parse_block(self, pos, &bstart, &br);
                    if (self->emit == 1) {
                        if (self->bitness == 32) {
                            Codegen.emit_line(self, "    movl (%esp), %ebx");
                            Codegen.emit_line(self, "    cmpl %eax, %ebx");
                            Codegen.emit_str(self, "    jne .L");
                            Codegen.emit_dec(self, case_next_lbl);
                            Codegen.emit_nl(self);
                        } else {
                            Codegen.emit_line(self, "    movq (%rsp), %r10");
                            Codegen.emit_line(self, "    cmpq %rax, %r10");
                            Codegen.emit_str(self, "    jne .L");
                            Codegen.emit_dec(self, case_next_lbl);
                            Codegen.emit_nl(self);
                        }
                    }
                    Codegen.parse_stmt_list(self, bstart, br);
                    if (self->emit == 1) {
                        Codegen.emit_str(self, "    jmp .L");
                        Codegen.emit_dec(self, end_lbl);
                        Codegen.emit_nl(self);
                        Codegen.emit_label(self, case_next_lbl);
                    }
                    continue;
                }
                if (Codegen.tok_is_default_kw(self, *pos) == 1) {
                    if (saw_default == 1) { cg_error("multiple default cases"); }
                    saw_default is 1;
                    *pos is *pos + 1;
                    bstart is 0;
                    br is 0;
                    Codegen.parse_block(self, pos, &bstart, &br);
                    Codegen.parse_stmt_list(self, bstart, br);
                    continue;
                }
                cg_error("expected case or default in match");
            }
            if (self->emit == 1) {
                Codegen.emit_line_bitness(self, "    addq $8, %rsp", "    addl $4, %esp");
                Codegen.emit_label(self, end_lbl);
            }
            if (*pos < end && Codegen.tok_punct1(self, *pos, 125) == 1) {
                *pos is *pos + 1;
            } else {
                Codegen.error_at(self, "expected '}'", *pos);
            }
            return;
        }

        if (VecToken.get_kind(self->toks, *pos) != TK_IDENT) { cg_error("expected statement"); }

        # Inline assembly: asm { ... }
        if (Codegen.tok_is_asm(self, *pos) == 1) {
            *pos is *pos + 1;
            if (VecToken.get_kind(self->toks, *pos) != TK_PUNCT || Codegen.tok_punct1(self, *pos, 123) == 0) {
                Codegen.error_at(self, "expected '{' after asm", *pos);
            }
            asm_lbrace is *pos;
            *pos is *pos + 1;
            asm_body_start is *pos;

            depth is 1;
            while (*pos < self->tok_count && depth > 0) {
                if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT) {
                    if (Codegen.tok_punct1(self, *pos, 123) == 1) { depth is depth + 1; }
                    else if (Codegen.tok_punct1(self, *pos, 125) == 1) { depth is depth - 1; }
                }
                *pos is *pos + 1;
            }
            if (depth != 0) { cg_error("unterminated asm block"); }
            asm_rbrace is *pos - 1;

            # Emit the raw assembly text between { and }, with variable substitution
            if (self->emit == 1) {
                asm_start_byte is VecToken.get_start(self->toks, asm_lbrace);
                asm_end_byte is VecToken.get_start(self->toks, asm_rbrace) + VecToken.get_len(self->toks, asm_rbrace);
                # Extract the text between the braces (exclusive)
                inner_start is asm_start_byte + 1;
                inner_end is asm_end_byte - 1;
                # Emit each line with variable substitution
                line_start is inner_start;
                for (int bi is inner_start; bi <= inner_end; bi is bi + 1) {
                    if (bi == inner_end || Codegen.byte_at(self, bi) == 10) {
                        line_len is bi - line_start;
                        if (line_len > 0) {
                            Codegen.emit_str(self, "    ");
                            # Scan the line for identifiers and substitute known variables
                            si is line_start;
                            si_end is line_start + line_len;
                            while (si < si_end) {
                                c is Codegen.byte_at(self, si);
                                # Check if this starts an identifier (alpha or underscore or dot)
                                if ((c >= 97 && c <= 122) || (c >= 65 && c <= 90) || c == 95 || c == 46) {
                                    id_start is si;
                                    si is si + 1;
                                    while (si < si_end) {
                                        c2 is Codegen.byte_at(self, si);
                                        if ((c2 >= 97 && c2 <= 122) || (c2 >= 65 && c2 <= 90) ||
                                            (c2 >= 48 && c2 <= 57) || c2 == 95 || c2 == 46) { si is si + 1; }
                                        else { break; }
                                    }
                                    id_len is si - id_start;
                                    # Look up as a local variable
                                    vidx is Codegen.vars_find(self, id_start, id_len);
                                    if (vidx >= 0) {
                                        off is Codegen.vars_get_off(self, vidx);
                                        # Emit Intel-syntax stack reference: [rbp - OFF]
                                        Codegen.emit_str(self, "QWORD PTR [rbp - ");
                                        Codegen.emit_dec(self, off);
                                        Codegen.emit_byte(self, 93); # ']'
                                    } else {
                                        # Not a local variable, emit as-is
                                        file_write(self->fd, self->src + id_start, id_len);
                                    }
                                } else {
                                    # Non-identifier character, emit as-is
                                    Codegen.emit_byte(self, c);
                                    si is si + 1;
                                }
                            }
                            Codegen.emit_nl(self);
                        }
                        line_start is bi + 1;
                    }
                }
            }
            return;
        }

        if (Codegen.tok_is_if(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;
            Codegen.parse_expr(self, pos);
            if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
            *pos is *pos + 1;

            else_lbl is Codegen.new_label(self);
            end_lbl is Codegen.new_label(self);

	            if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
	                Codegen.emit_str(self, "    jz .L");
	                Codegen.emit_dec(self, else_lbl);
	                Codegen.emit_nl(self);
	            }

            bstart is 0;
            br is 0;
            Codegen.parse_block(self, pos, &bstart, &br);
            Codegen.parse_stmt_list(self, bstart, br);

            if (self->emit == 1) {
                Codegen.emit_str(self, "    jmp .L");
                Codegen.emit_dec(self, end_lbl);
                Codegen.emit_nl(self);
                Codegen.emit_label(self, else_lbl);
            }

            # Optional else
            if (*pos < end && Codegen.tok_is_else(self, *pos) == 1) {
                *pos is *pos + 1;
                if (*pos < end && Codegen.tok_is_if(self, *pos) == 1) {
                    Codegen.parse_stmt(self, pos, end);
                } else {
                    bstart2 is 0;
                    br2 is 0;
                    Codegen.parse_block(self, pos, &bstart2, &br2);
                    Codegen.parse_stmt_list(self, bstart2, br2);
                }
            }

            if (self->emit == 1) { Codegen.emit_label(self, end_lbl); }
            return;
        }

        if (Codegen.tok_is_while(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;

            start_lbl is Codegen.new_label(self);
            end_lbl is Codegen.new_label(self);

            VecInt.push(self->break_stack, end_lbl);
            VecInt.push(self->cont_stack, start_lbl);

            if (self->emit == 1) { Codegen.emit_label(self, start_lbl); }
            Codegen.parse_expr(self, pos);
            if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
            *pos is *pos + 1;

	            if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
	                Codegen.emit_str(self, "    jz .L");
	                Codegen.emit_dec(self, end_lbl);
	                Codegen.emit_nl(self);
	            }

            bstart is 0;
            br is 0;
            Codegen.parse_block(self, pos, &bstart, &br);
            Codegen.parse_stmt_list(self, bstart, br);

            if (self->emit == 1) {
                Codegen.emit_str(self, "    jmp .L");
                Codegen.emit_dec(self, start_lbl);
                Codegen.emit_nl(self);
                Codegen.emit_label(self, end_lbl);
            }

            # pop loop labels
            VecInt.pop(self->break_stack);
            VecInt.pop(self->cont_stack);
            return;
        }

        if (Codegen.tok_is_for(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;

            # init
            if (Codegen.tok_punct1(self, *pos, 59) == 1) { *pos is *pos + 1; }
            else { Codegen.parse_bind_assign(self, pos, 59, 1); }

            cond_lbl is Codegen.new_label(self);
            post_lbl is Codegen.new_label(self);
            end_lbl is Codegen.new_label(self);

            VecInt.push(self->break_stack, end_lbl);
            VecInt.push(self->cont_stack, post_lbl);

            if (self->emit == 1) { Codegen.emit_label(self, cond_lbl); }

            # cond
	            if (Codegen.tok_punct1(self, *pos, 59) == 1) {
	                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    movq $1, %rax", "    movl $1, %eax"); }
	                *pos is *pos + 1;
	            } else {
                Codegen.parse_expr(self, pos);
                if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
                *pos is *pos + 1;
            }

	            if (self->emit == 1) {
	                Codegen.emit_line_bitness(self, "    testq %rax, %rax", "    testl %eax, %eax");
	                Codegen.emit_str(self, "    jz .L");
	                Codegen.emit_dec(self, end_lbl);
	                Codegen.emit_nl(self);
	            }

            # post (record start/end and parse twice)
            post_start is *pos;
            depth is 1;
            while (*pos < self->tok_count && depth > 0) {
                if (VecToken.get_kind(self->toks, *pos) == TK_PUNCT && Codegen.tok_punct1(self, *pos, 41) == 1) { break; }
                *pos is *pos + 1;
            }
            post_end is *pos;
            if (Codegen.tok_punct1(self, *pos, 41) == 0) { Codegen.error_at(self, "expected ')'", *pos); }
            *pos is *pos + 1;

            bstart is 0;
            br is 0;
            Codegen.parse_block(self, pos, &bstart, &br);
            Codegen.parse_stmt_list(self, bstart, br);

            if (self->emit == 1) { Codegen.emit_label(self, post_lbl); }

            # parse post assignment if non-empty
            if (post_start < post_end) {
                ppos is post_start;
                Codegen.parse_bind_assign(self, &ppos, 41, 0);
            }

            if (self->emit == 1) {
                Codegen.emit_str(self, "    jmp .L");
                Codegen.emit_dec(self, cond_lbl);
                Codegen.emit_nl(self);
                Codegen.emit_label(self, end_lbl);
            }

            VecInt.pop(self->break_stack);
            VecInt.pop(self->cont_stack);
            return;
        }

        if (Codegen.tok_is_break(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
            if (self->emit == 1) {
                n is VecInt.count(self->break_stack);
                if (n <= 0) { cg_error("break outside loop"); }
                lbl is VecInt.get(self->break_stack, n - 1);
                Codegen.emit_str(self, "    jmp .L");
                Codegen.emit_dec(self, lbl);
                Codegen.emit_nl(self);
            }
            return;
        }

        if (Codegen.tok_is_continue(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
            if (self->emit == 1) {
                n is VecInt.count(self->cont_stack);
                if (n <= 0) { cg_error("continue outside loop"); }
                lbl is VecInt.get(self->cont_stack, n - 1);
                Codegen.emit_str(self, "    jmp .L");
                Codegen.emit_dec(self, lbl);
                Codegen.emit_nl(self);
            }
            return;
        }

        if (Codegen.tok_is_return(self, *pos) == 1) {
            *pos is *pos + 1;
	            if (Codegen.tok_punct1(self, *pos, 59) == 0) {
	                Codegen.parse_expr(self, pos);
	            } else {
	                if (self->emit == 1) { Codegen.emit_line_bitness(self, "    xorq %rax, %rax", "    xorl %eax, %eax"); }
	            }
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
            if (self->emit == 1) {
                if (self->cur_ret_label < 0) { cg_error("internal: missing ret label"); }
                Codegen.emit_str(self, "    jmp .Lret_");
                Codegen.emit_dec(self, self->cur_ret_label);
                Codegen.emit_nl(self);
            }
            return;
        }

        if (Codegen.tok_is_txtout(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;
            first is 1;
            while (Codegen.tok_punct1(self, *pos, 41) == 0) {
                if (first == 0) {
                    if (Codegen.tok_punct1(self, *pos, 44) == 0) { cg_error("expected ','"); }
                    *pos is *pos + 1;
                }
                first is 0;

	                ty is Codegen.parse_expr(self, pos);
	                if (self->emit == 1) {
	                    if (self->bitness == 32) {
	                        Codegen.emit_call_prep(self, 2);
	                        Codegen.emit_line(self, "    pushl %eax");
	                        if (ty == TY_STRING) { Codegen.emit_line(self, "    pushl $fmt_str"); }
	                        else { Codegen.emit_line(self, "    pushl $fmt_int"); }
	                        Codegen.emit_line(self, "    call __zinc_rt_printf");
	                        Codegen.emit_call_cleanup(self, 2);
	                    } else {
	                        Codegen.emit_line(self, "    movq %rax, %rsi");
	                        if (ty == TY_STRING) { Codegen.emit_line(self, "    leaq fmt_str(%rip), %rdi"); }
	                        else { Codegen.emit_line(self, "    leaq fmt_int(%rip), %rdi"); }
	                        Codegen.emit_line(self, "    xorl %eax, %eax");
	                        Codegen.emit_line(self, "    call __zinc_rt_printf");
	                    }
	                }
            }
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
	        if (self->emit == 1) {
	            if (self->bitness == 32) {
	                Codegen.emit_call_prep(self, 1);
	                Codegen.emit_line(self, "    pushl $fmt_nl");
	                Codegen.emit_line(self, "    call __zinc_rt_printf");
	                Codegen.emit_call_cleanup(self, 1);
	            } else {
	                Codegen.emit_line(self, "    leaq fmt_nl(%rip), %rdi");
	                Codegen.emit_line(self, "    xorl %eax, %eax");
	                Codegen.emit_line(self, "    call __zinc_rt_printf");
	            }
	        }
            return;
        }

        if (Codegen.tok_is_txtout_nl(self, *pos) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;
            first is 1;
            while (Codegen.tok_punct1(self, *pos, 41) == 0) {
                if (first == 0) {
                    if (Codegen.tok_punct1(self, *pos, 44) == 0) { cg_error("expected ','"); }
                    *pos is *pos + 1;
                }
                first is 0;

	                ty is Codegen.parse_expr(self, pos);
	                if (self->emit == 1) {
	                    if (self->bitness == 32) {
	                        Codegen.emit_call_prep(self, 2);
	                        Codegen.emit_line(self, "    pushl %eax");
	                        if (ty == TY_STRING) { Codegen.emit_line(self, "    pushl $fmt_str"); }
	                        else { Codegen.emit_line(self, "    pushl $fmt_int"); }
	                        Codegen.emit_line(self, "    call __zinc_rt_printf");
	                        Codegen.emit_call_cleanup(self, 2);
	                    } else {
	                        Codegen.emit_line(self, "    movq %rax, %rsi");
	                        if (ty == TY_STRING) { Codegen.emit_line(self, "    leaq fmt_str(%rip), %rdi"); }
	                        else { Codegen.emit_line(self, "    leaq fmt_int(%rip), %rdi"); }
	                        Codegen.emit_line(self, "    xorl %eax, %eax");
	                        Codegen.emit_line(self, "    call __zinc_rt_printf");
	                    }
	                }
            }
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
            return;
        }

        if (Codegen.tok_is_out(self, *pos) == 1 &&
            *pos + 1 < self->tok_count &&
            VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
            Codegen.tok_punct1(self, *pos + 1, 40) == 1) {
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 40) == 0) { Codegen.error_at(self, "expected '('", *pos); }
            *pos is *pos + 1;
            ty is Codegen.parse_expr(self, pos);
            if (ty != TY_INT) { cg_error("out expects int"); }
            if (Codegen.tok_punct1(self, *pos, 41) == 0) { cg_error("expected ')'"); }
            *pos is *pos + 1;
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;
	        if (self->emit == 1) {
	            if (self->bitness == 32) {
	                Codegen.emit_call_prep(self, 1);
	                Codegen.emit_line(self, "    pushl %eax");
	                Codegen.emit_line(self, "    call __zinc_rt_exit");
	                Codegen.emit_call_cleanup(self, 1);
	            } else {
	                Codegen.emit_line(self, "    movq %rax, %rdi");
	                Codegen.emit_line(self, "    call __zinc_rt_exit");
	            }
	        }
            return;
        }

        # Member assignment: obj(.|->)field is expr;
        if (*pos + 3 < end &&
            *pos + 3 < self->tok_count &&
            VecToken.get_kind(self->toks, *pos) == TK_IDENT &&
            VecToken.get_kind(self->toks, *pos + 1) == TK_PUNCT &&
            (Codegen.tok_punct1(self, *pos + 1, 46) == 1 || Codegen.tok_punct2(self, *pos + 1, 45, 62) == 1) &&
            VecToken.get_kind(self->toks, *pos + 2) == TK_IDENT &&
            VecToken.get_kind(self->toks, *pos + 3) == TK_IDENT &&
            Codegen.tok_is_is(self, *pos + 3) == 1) {
            obj_start is VecToken.get_start(self->toks, *pos);
            obj_len is VecToken.get_len(self->toks, *pos);
            vidx is Codegen.vars_find(self, obj_start, obj_len);
            if (vidx < 0) { cg_error("unknown object"); }
            obj_ty is Codegen.vars_get_type(self, vidx);
            cls is class_idx_from_ty(obj_ty);
            if (cls < 0) { cg_error("member assign on non-object"); }

            mem_start is VecToken.get_start(self->toks, *pos + 2);
            mem_len is VecToken.get_len(self->toks, *pos + 2);
            off is Codegen.field_offset(self, cls, mem_start, mem_len);
            if (off < 0) { Codegen.error_at(self, "unknown field", *pos + 2); }

            *pos is *pos + 4; # obj op member is
            Codegen.parse_expr(self, pos);
            if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
            *pos is *pos + 1;

	            if (self->emit == 1) {
	                voff is Codegen.vars_get_off(self, vidx);
	                if (self->bitness == 32) {
	                    Codegen.emit_str(self, "    movl -");
	                    Codegen.emit_dec(self, voff);
	                    Codegen.emit_line(self, "(%ebp), %ebx");
	                    Codegen.emit_str(self, "    movl %eax, ");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%ebx)");
	                } else {
	                    Codegen.emit_str(self, "    movq -");
	                    Codegen.emit_dec(self, voff);
	                    Codegen.emit_line(self, "(%rbp), %r10");
	                    Codegen.emit_str(self, "    movq %rax, ");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%r10)");
	                }
	            }
            return;
        }

        # assignment/binding statement (including inferred vars)
        if (Codegen.tok_is_int(self, *pos) == 1 || Codegen.tok_is_float_kw(self, *pos) == 1 ||
            Codegen.tok_is_bool_kw(self, *pos) == 1 || Codegen.tok_is_string_kw(self, *pos) == 1 ||
            (VecToken.get_kind(self->toks, *pos) == TK_IDENT && *pos + 1 < self->tok_count && Codegen.tok_is_is(self, *pos + 1) == 1)) {
            Codegen.parse_bind_assign(self, pos, 59, 1);
            return;
        }

        # Expression statement (calls, method calls, etc.)
        Codegen.parse_expr(self, pos);
        if (Codegen.tok_punct1(self, *pos, 59) == 0) { Codegen.error_at(self, "expected ';'", *pos); }
        *pos is *pos + 1;
        return;
    }

    func void parse_stmt_list(int* self, int start, int end) {
        pos is start;
        while (pos < end) { Codegen.parse_stmt(self, &pos, end); }
    }

    func void compile(int* self, string out_path) {
        # Scan top-level func declarations.
        funcs is VecInt();
        VecInt.init(funcs);
        globals is VecInt();
        VecInt.init(globals);
        classes is VecInt();
        VecInt.init(classes);
        fields is VecInt();
        VecInt.init(fields);
        enums is VecInt();
        VecInt.init(enums);
        enum_vals is VecInt();
        VecInt.init(enum_vals);
        self->fns is funcs;
        self->globals is globals;
        self->classes is classes;
        self->fields is fields;
        self->enums is enums;
        self->enum_vals is enum_vals;
        func_locals is VecInt();
        VecInt.init(func_locals);
        func_params is VecInt();
        VecInt.init(func_params);
        func_retlabels is VecInt();
        VecInt.init(func_retlabels);

        pos is 0;
        while (pos < self->tok_count && VecToken.get_kind(self->toks, pos) != TK_EOF) {
            # Class declaration: class Name { ... }
            if (Codegen.tok_is_class_kw(self, pos) == 1 || Codegen.tok_is_struct_kw(self, pos) == 1) {
                if (VecToken.get_kind(self->toks, pos + 1) != TK_IDENT) { cg_error("expected class name"); }
                cname_start is VecToken.get_start(self->toks, pos + 1);
                cname_len is VecToken.get_len(self->toks, pos + 1);
                allow_methods is 1;
                if (Codegen.tok_is_struct_kw(self, pos) == 1) { allow_methods is 0; }

                p is pos + 2;
                while (p < self->tok_count &&
                       !(VecToken.get_kind(self->toks, p) == TK_PUNCT && Codegen.tok_punct1(self, p, 123) == 1)) {
                    p is p + 1;
                }
                if (p >= self->tok_count) { cg_error("expected '{' after class"); }
                body_lbrace is p;

                depth is 1;
                p is p + 1;
                while (p < self->tok_count && depth > 0) {
                    if (VecToken.get_kind(self->toks, p) == TK_PUNCT) {
                        if (Codegen.tok_punct1(self, p, 123) == 1) { depth is depth + 1; }
                        else if (Codegen.tok_punct1(self, p, 125) == 1) { depth is depth - 1; }
                    }
                    p is p + 1;
                }
                if (depth != 0) { cg_error("unterminated class body"); }
                body_rbrace is p - 1;

                class_idx is VecInt.count(classes) / 3;
                VecInt.push(classes, cname_start);
                VecInt.push(classes, cname_len);
                VecInt.push(classes, 0);

                fieldc is 0;
                i is body_lbrace + 1;
                while (i < body_rbrace) {
                    if (allow_methods == 1 && i + 2 < body_rbrace && Codegen.tok_is_func(self, i) == 1) {
                        if (VecToken.get_kind(self->toks, i + 1) != TK_IDENT) { cg_error("expected return type"); }
                        if (VecToken.get_kind(self->toks, i + 2) != TK_IDENT) { cg_error("expected method name"); }

                        ret_ty is TY_INT;
                        if (Codegen.tok_is_void_kw(self, i + 1) == 1) { ret_ty is TY_VOID; }
                        else if (Codegen.tok_is_string_kw(self, i + 1) == 1) { ret_ty is TY_STRING; }

                        mname_start is VecToken.get_start(self->toks, i + 2);
                        mname_len is VecToken.get_len(self->toks, i + 2);

                        mp is i + 3;
                        while (mp < self->tok_count && !(VecToken.get_kind(self->toks, mp) == TK_PUNCT && Codegen.tok_punct1(self, mp, 40) == 1)) {
                            mp is mp + 1;
                        }
                        if (mp >= self->tok_count) { Codegen.error_at(self, "expected '('", mp); }
                        param_start is mp + 1;

                        depth2 is 1;
                        mp is mp + 1;
                        while (mp < self->tok_count && depth2 > 0) {
                            if (VecToken.get_kind(self->toks, mp) == TK_PUNCT) {
                                if (Codegen.tok_punct1(self, mp, 40) == 1) { depth2 is depth2 + 1; }
                                else if (Codegen.tok_punct1(self, mp, 41) == 1) { depth2 is depth2 - 1; }
                            }
                            mp is mp + 1;
                        }
                        if (depth2 != 0) { cg_error("unterminated param list"); }
                        param_end is mp - 1;

                        while (mp < self->tok_count && !(VecToken.get_kind(self->toks, mp) == TK_PUNCT && Codegen.tok_punct1(self, mp, 123) == 1)) {
                            mp is mp + 1;
                        }
                        if (mp >= self->tok_count) { cg_error("expected '{'"); }
                        body_start is mp + 1;

                        depth3 is 1;
                        mp is mp + 1;
                        while (mp < self->tok_count && depth3 > 0) {
                            if (VecToken.get_kind(self->toks, mp) == TK_PUNCT) {
                                if (Codegen.tok_punct1(self, mp, 123) == 1) { depth3 is depth3 + 1; }
                                else if (Codegen.tok_punct1(self, mp, 125) == 1) { depth3 is depth3 - 1; }
                            }
                            mp is mp + 1;
                        }
                        if (depth3 != 0) { cg_error("unterminated method body"); }
                        body_end is mp - 1;

                        is_instance is 0;
                        if (param_start < param_end && VecToken.get_kind(self->toks, param_start) == TK_IDENT) {
                            pp is param_start + 1;
                            starc is 0;
                            while (pp < param_end && VecToken.get_kind(self->toks, pp) == TK_PUNCT && Codegen.tok_punct1(self, pp, 42) == 1) { starc is starc + 1; pp is pp + 1; }
                            if (starc > 0) { is_instance is 1; }
                        }

                        VecInt.push(funcs, 1);
                        VecInt.push(funcs, class_idx);
                        VecInt.push(funcs, cname_start);
                        VecInt.push(funcs, cname_len);
                        VecInt.push(funcs, mname_start);
                        VecInt.push(funcs, mname_len);
                        VecInt.push(funcs, ret_ty);
                        VecInt.push(funcs, param_start);
                        VecInt.push(funcs, param_end);
                        VecInt.push(funcs, body_start);
                        VecInt.push(funcs, body_end);
                        VecInt.push(funcs, is_instance);

                        i is body_end + 1;
                        continue;
                    }

                    if (VecToken.get_kind(self->toks, i) == TK_IDENT) {
                        j is i + 1;
                        while (j < body_rbrace &&
                               VecToken.get_kind(self->toks, j) == TK_PUNCT &&
                               Codegen.tok_punct1(self, j, 42) == 1) { j is j + 1; }
                        if (j + 1 < body_rbrace &&
                            VecToken.get_kind(self->toks, j) == TK_IDENT &&
                            VecToken.get_kind(self->toks, j + 1) == TK_PUNCT &&
                            Codegen.tok_punct1(self, j + 1, 59) == 1) {
                            fname_start is VecToken.get_start(self->toks, j);
                            fname_len is VecToken.get_len(self->toks, j);
                            VecInt.push(fields, class_idx);
                            VecInt.push(fields, fname_start);
                            VecInt.push(fields, fname_len);
                            VecInt.push(fields, fieldc * self->word_size);
                            fieldc is fieldc + 1;
                            i is j + 2;
                            continue;
                        }
                    }

                    i is i + 1;
                }

                VecInt.set(classes, class_idx * 3 + 2, fieldc * self->word_size);
                pos is body_rbrace + 1;
                continue;
            }

            # Enum declaration: enum Name { A; B; }
            if (Codegen.tok_is_enum_kw(self, pos) == 1) {
                if (VecToken.get_kind(self->toks, pos + 1) != TK_IDENT) { cg_error("expected enum name"); }
                ename_start is VecToken.get_start(self->toks, pos + 1);
                ename_len is VecToken.get_len(self->toks, pos + 1);

                p is pos + 2;
                while (p < self->tok_count &&
                       !(VecToken.get_kind(self->toks, p) == TK_PUNCT && Codegen.tok_punct1(self, p, 123) == 1)) {
                    p is p + 1;
                }
                if (p >= self->tok_count) { cg_error("expected '{' after enum"); }
                body_lbrace is p;

                depth is 1;
                p is p + 1;
                while (p < self->tok_count && depth > 0) {
                    if (VecToken.get_kind(self->toks, p) == TK_PUNCT) {
                        if (Codegen.tok_punct1(self, p, 123) == 1) { depth is depth + 1; }
                        else if (Codegen.tok_punct1(self, p, 125) == 1) { depth is depth - 1; }
                    }
                    p is p + 1;
                }
                if (depth != 0) { cg_error("unterminated enum body"); }
                body_rbrace is p - 1;

                enum_idx is VecInt.count(enums) / 4;
                VecInt.push(enums, ename_start);
                VecInt.push(enums, ename_len);
                VecInt.push(enums, VecInt.count(enum_vals) / 4);

                variantc is 0;
                cur_val is 0;
                i is body_lbrace + 1;
                while (i < body_rbrace) {
                    if (VecToken.get_kind(self->toks, i) == TK_IDENT) {
                        vstart is VecToken.get_start(self->toks, i);
                        vlen is VecToken.get_len(self->toks, i);
                        VecInt.push(enum_vals, enum_idx);
                        VecInt.push(enum_vals, vstart);
                        VecInt.push(enum_vals, vlen);
                        VecInt.push(enum_vals, cur_val);
                        cur_val is cur_val + 1;
                        variantc is variantc + 1;
                        i is i + 1;
                        if (i < body_rbrace && VecToken.get_kind(self->toks, i) == TK_PUNCT &&
                            (Codegen.tok_punct1(self, i, 59) == 1 || Codegen.tok_punct1(self, i, 44) == 1)) {
                            i is i + 1;
                        }
                        continue;
                    }
                    i is i + 1;
                }
                VecInt.push(enums, variantc);
                pos is body_rbrace + 1;
                continue;
            }

            # Global constant: NAME is <literal>;
            if (VecToken.get_kind(self->toks, pos) == TK_IDENT &&
                pos + 2 < self->tok_count &&
                Codegen.tok_is_is(self, pos + 1) == 1) {
                name_start is VecToken.get_start(self->toks, pos);
                name_len is VecToken.get_len(self->toks, pos);
                p is pos + 2;

                gty is 0;
                gval is 0;
                k is VecToken.get_kind(self->toks, p);
                if (k == TK_NUMBER) {
                    start is VecToken.get_start(self->toks, p);
                    ln is VecToken.get_len(self->toks, p);
                    v is 0;
                    if (ln >= 3 && Codegen.byte_at(self, start + 0) == 48 &&
                        (Codegen.byte_at(self, start + 1) == 120 || Codegen.byte_at(self, start + 1) == 88)) {
                        for (int i is 2; i < ln; i is i + 1) {
                            c is Codegen.byte_at(self, start + i);
                            if (c >= 48 && c <= 57) { v is v * 16 + (c - 48); }
                            else if (c >= 65 && c <= 70) { v is v * 16 + (c - 65 + 10); }
                            else if (c >= 97 && c <= 102) { v is v * 16 + (c - 97 + 10); }
                        }
                    } else {
                        for (int i is 0; i < ln; i is i + 1) { v is v * 10 + (Codegen.byte_at(self, start + i) - 48); }
                    }
                    gty is TY_INT;
                    gval is v;
                    p is p + 1;
                } else if (k == TK_STRING) {
                    start is VecToken.get_start(self->toks, p);
                    ln is VecToken.get_len(self->toks, p);
                    idx is Codegen.strtab_intern(self, start + 1, ln - 2);
                    gty is TY_STRING;
                    gval is idx;
                    p is p + 1;
                } else if (k == TK_IDENT && Codegen.tok_is_true(self, p) == 1) {
                    gty is TY_INT;
                    gval is 1;
                    p is p + 1;
                } else if (k == TK_IDENT && Codegen.tok_is_false(self, p) == 1) {
                    gty is TY_INT;
                    gval is 0;
                    p is p + 1;
                } else if (k == TK_IDENT && Codegen.tok_is_nullptr(self, p) == 1) {
                    gty is TY_INT;
                    gval is 0;
                    p is p + 1;
                } else {
                    gty is 0;
                }

                if (gty != 0 &&
                    VecToken.get_kind(self->toks, p) == TK_PUNCT &&
                    Codegen.tok_punct1(self, p, 59) == 1) {
                    VecInt.push(globals, name_start);
                    VecInt.push(globals, name_len);
                    VecInt.push(globals, gty);
                    VecInt.push(globals, gval);
                    pos is p + 1;
                    continue;
                }
            }

            # Skip extern function declarations (no body needed, linker resolves)
            if (Codegen.tok_is_extern(self, pos) == 1) {
                if (pos + 1 >= self->tok_count) { cg_error("expected func after extern"); }
                if (Codegen.tok_is_func(self, pos + 1) == 0) { cg_error("extern requires func"); }
                # extern func <ret> <name>(params);
                # Skip: extern func ret name ( params ) ;
                p is pos + 2;
                # Skip return type
                if (VecToken.get_kind(self->toks, p) != TK_IDENT) { cg_error("expected return type"); }
                p is p + 1;
                # Skip function name
                if (VecToken.get_kind(self->toks, p) != TK_IDENT) { cg_error("expected function name"); }
                p is p + 1;
                # Skip param list
                if (VecToken.get_kind(self->toks, p) != TK_PUNCT || Codegen.tok_punct1(self, p, 40) == 0) { cg_error("expected '('"); }
                p is p + 1;
                depth is 1;
                while (p < self->tok_count && depth > 0) {
                    if (VecToken.get_kind(self->toks, p) == TK_PUNCT) {
                        if (Codegen.tok_punct1(self, p, 40) == 1) { depth is depth + 1; }
                        else if (Codegen.tok_punct1(self, p, 41) == 1) { depth is depth - 1; }
                    }
                    p is p + 1;
                }
                if (depth != 0) { cg_error("unterminated param list"); }
                # Skip semicolon
                if (VecToken.get_kind(self->toks, p) != TK_PUNCT || Codegen.tok_punct1(self, p, 59) == 0) { cg_error("expected ';' after extern func"); }
                pos is p + 1;
                continue;
            }

            if (Codegen.tok_is_func(self, pos) == 1) {
                # func <ret> <name> ( ... ) { ... }
                if (VecToken.get_kind(self->toks, pos + 1) != TK_IDENT) { cg_error("expected return type"); }
                if (VecToken.get_kind(self->toks, pos + 2) != TK_IDENT) { cg_error("expected function name"); }

                ret_ty is TY_INT;
                if (Codegen.tok_is_void_kw(self, pos + 1) == 1) { ret_ty is TY_VOID; }
                else if (Codegen.tok_is_string_kw(self, pos + 1) == 1) { ret_ty is TY_STRING; }

                name_start is VecToken.get_start(self->toks, pos + 2);
                name_len is VecToken.get_len(self->toks, pos + 2);

                p is pos + 3;
                while (p < self->tok_count && !(VecToken.get_kind(self->toks, p) == TK_PUNCT && Codegen.tok_punct1(self, p, 40) == 1)) {
                    p is p + 1;
                }
                if (p >= self->tok_count) { Codegen.error_at(self, "expected '('", p); }
                param_start is p + 1;

                depth is 1;
                p is p + 1;
                while (p < self->tok_count && depth > 0) {
                    if (VecToken.get_kind(self->toks, p) == TK_PUNCT) {
                        if (Codegen.tok_punct1(self, p, 40) == 1) { depth is depth + 1; }
                        else if (Codegen.tok_punct1(self, p, 41) == 1) { depth is depth - 1; }
                    }
                    p is p + 1;
                }
                if (depth != 0) { cg_error("unterminated param list"); }
                param_end is p - 1; # ')'

                while (p < self->tok_count && !(VecToken.get_kind(self->toks, p) == TK_PUNCT && Codegen.tok_punct1(self, p, 123) == 1)) {
                    p is p + 1;
                }
                if (p >= self->tok_count) { cg_error("expected '{'"); }
                body_start is p + 1;

                depth is 1;
                p is p + 1;
                while (p < self->tok_count && depth > 0) {
                    if (VecToken.get_kind(self->toks, p) == TK_PUNCT) {
                        if (Codegen.tok_punct1(self, p, 123) == 1) { depth is depth + 1; }
                        else if (Codegen.tok_punct1(self, p, 125) == 1) { depth is depth - 1; }
                    }
                    p is p + 1;
                }
                if (depth != 0) { cg_error("unterminated function body"); }
                body_end is p - 1; # '}'

                # Record func (stride=12):
                # kind(0=plain,1=method), class_idx, class_name_start, class_name_len,
                # name_start, name_len, ret_ty, param_start, param_end, body_start, body_end, is_instance
                VecInt.push(funcs, 0);
                VecInt.push(funcs, -1);
                VecInt.push(funcs, 0);
                VecInt.push(funcs, 0);
                VecInt.push(funcs, name_start);
                VecInt.push(funcs, name_len);
                VecInt.push(funcs, ret_ty);
                VecInt.push(funcs, param_start);
                VecInt.push(funcs, param_end);
                VecInt.push(funcs, body_start);
                VecInt.push(funcs, body_end);
                VecInt.push(funcs, 0);

                pos is body_end + 1;
                continue;
            }
            pos is pos + 1;
        }

        # DEBUG: sanity check class scan
        # txtout("DBG classes_count=", Codegen.classes_count(self));

        fn_count is VecInt.count(funcs) / 12;
        if (fn_count == 0) { cg_error("no functions found"); }

        # Prepass: compute locals per function and intern strings.
        for (int fi is 0; fi < fn_count; fi is fi + 1) {
            # reset vars
            if (self->vars == 0) { self->vars is VecInt(); VecInt.init(self->vars); }
            else { VecInt.clear(self->vars); }
            VecInt.clear(self->break_stack);
            VecInt.clear(self->cont_stack);

            fn_kind is VecInt.get(funcs, fi * 12 + 0);
            fn_class_idx is VecInt.get(funcs, fi * 12 + 1);
            fn_is_instance is VecInt.get(funcs, fi * 12 + 11);
            self->cur_fn_kind is fn_kind;
            self->cur_fn_class_idx is fn_class_idx;
            self->cur_fn_is_instance is fn_is_instance;
            self->cur_self_off is 0;
            self->cur_fn_name_start is VecInt.get(funcs, fi * 12 + 4);
            self->cur_fn_name_len is VecInt.get(funcs, fi * 12 + 5);
            self->cur_fn_ret_ty is VecInt.get(funcs, fi * 12 + 6);

            pstart is VecInt.get(funcs, fi * 12 + 7);
            pend is VecInt.get(funcs, fi * 12 + 8);

            # params: <type> [*]* <name> (ignore arrays)
            ppos is pstart;
            paramc is 0;
            while (ppos < pend) {
                if (VecToken.get_kind(self->toks, ppos) != TK_IDENT) { break; }
                base_is_string is Codegen.tok_is_string_kw(self, ppos);
                base_is_char is Codegen.tok_is_char_kw(self, ppos);
                pty is TY_INT;
                if (base_is_string == 1) { pty is TY_STRING; }
                ppos is ppos + 1;
                starc is 0;
                while (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 42) == 1) { starc is starc + 1; ppos is ppos + 1; }
                if (VecToken.get_kind(self->toks, ppos) != TK_IDENT) { cg_error("bad param"); }
                ns is VecToken.get_start(self->toks, ppos);
                nl is VecToken.get_len(self->toks, ppos);
                ppos is ppos + 1;
                # skip [] if present
                has_arr is 0;
                if (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 91) == 1) {
                    if (Codegen.tok_punct1(self, ppos + 1, 93) == 1) { ppos is ppos + 2; }
                    has_arr is 1;
                }

                if (fn_kind == 1 && fn_is_instance == 1 && paramc == 0) {
                    pty is TY_CLASS_BASE + fn_class_idx;
                } else if (base_is_char == 1 && starc > 0 && has_arr == 1) {
                    pty is TY_STR_ARR;
                } else if (base_is_char == 1 && starc > 0) {
                    pty is TY_STRING;
                }

                off is (paramc + 1) * self->word_size;
                Codegen.vars_add(self, ns, nl, pty, off, 0);
                if (fn_kind == 1 && fn_is_instance == 1 && paramc == 0) { self->cur_self_off is off; }
                paramc is paramc + 1;
                if (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 44) == 1) { ppos is ppos + 1; continue; }
                break;
            }

            self->emit is 0;
            self->cur_ret_label is self->label_counter;
            self->label_counter is self->label_counter + 1;
            VecInt.push(func_retlabels, self->cur_ret_label);

            bstart is VecInt.get(funcs, fi * 12 + 9);
            bend is VecInt.get(funcs, fi * 12 + 10);
            Codegen.parse_stmt_list(self, bstart, bend);

            local_bytes is Codegen.vars_count(self) * self->word_size;
            if (self->bitness == 32) {
                # Keep stack 16-byte aligned before calls:
                # entry: esp%16==12, push ebp -> 8, push ebx -> 4, sub locals -> 0 when locals%16==4
                mod is local_bytes % 16;
                if (mod != 4) { local_bytes is local_bytes + ((4 - mod + 16) % 16); }
            } else {
                # Keep stack 16-byte aligned (SysV x86-64) after `push %rbp` so libc calls are safe.
                if (local_bytes % 16 != 0) { local_bytes is local_bytes + (16 - (local_bytes % 16)); }
            }
            VecInt.push(func_locals, local_bytes);
            VecInt.push(func_params, paramc);
        }

        fd is file_open_write(out_path);
        if (fd == -1) { cg_error("failed to open output"); }
        self->fd is fd;

	        Codegen.emit_line(self, ".section .data");
	        Codegen.emit_str(self, "fmt_int: .string ");
	        Codegen.emit_byte(self, 34);
	        if (self->bitness == 32) { Codegen.emit_str(self, "%d"); }
	        else { Codegen.emit_str(self, "%ld"); }
	        Codegen.emit_byte(self, 34);
	        Codegen.emit_nl(self);

        Codegen.emit_str(self, "fmt_str: .string ");
        Codegen.emit_byte(self, 34);
        Codegen.emit_str(self, "%s");
        Codegen.emit_byte(self, 34);
        Codegen.emit_nl(self);

        Codegen.emit_str(self, "fmt_nl: .string ");
        Codegen.emit_byte(self, 34);
        Codegen.emit_byte(self, 92);
        Codegen.emit_byte(self, 110);
        Codegen.emit_byte(self, 34);
        Codegen.emit_nl(self);

        sc is Codegen.strtab_count(self);
        for (int i is 0; i < sc; i is i + 1) {
            Codegen.emit_asm_string_escaped(self, i, Codegen.strtab_get_start(self, i), Codegen.strtab_get_len(self, i));
        }

        Codegen.emit_line(self, "");
        Codegen.emit_line(self, ".section .text");
        Codegen.emit_runtime_helpers(self);
        Codegen.emit_class_helpers(self);

        # Emit all functions.
        for (int fi is 0; fi < fn_count; fi is fi + 1) {
            local_bytes is VecInt.get(func_locals, fi);
            paramc is VecInt.get(func_params, fi);
            self->cur_ret_label is VecInt.get(func_retlabels, fi);

            Codegen.emit_line(self, "");
            Codegen.emit_str(self, ".globl ");
            Codegen.emit_fn_symbol(self, fi);
            Codegen.emit_nl(self);

	            Codegen.emit_fn_symbol(self, fi);
	            Codegen.emit_line(self, ":");
	            if (self->bitness == 32) {
	                Codegen.emit_line(self, "    pushl %ebp");
	                Codegen.emit_line(self, "    movl %esp, %ebp");
	                Codegen.emit_line(self, "    pushl %ebx");
	                if (local_bytes > 0) {
	                    Codegen.emit_str(self, "    subl $");
	                    Codegen.emit_dec(self, local_bytes);
	                    Codegen.emit_line(self, ", %esp");
	                }
	            } else {
	                Codegen.emit_line(self, "    pushq %rbp");
	                Codegen.emit_line(self, "    movq %rsp, %rbp");
	                if (local_bytes > 0) {
	                    Codegen.emit_str(self, "    subq $");
	                    Codegen.emit_dec(self, local_bytes);
	                    Codegen.emit_line(self, ", %rsp");
	                }
	            }

            # reset vars and add params again (so body emission can resolve them).
            if (self->vars == 0) { self->vars is VecInt(); VecInt.init(self->vars); }
            else { VecInt.clear(self->vars); }
            VecInt.clear(self->break_stack);
            VecInt.clear(self->cont_stack);

            fn_kind is VecInt.get(funcs, fi * 12 + 0);
            fn_class_idx is VecInt.get(funcs, fi * 12 + 1);
            fn_is_instance is VecInt.get(funcs, fi * 12 + 11);
            self->cur_fn_kind is fn_kind;
            self->cur_fn_class_idx is fn_class_idx;
            self->cur_fn_is_instance is fn_is_instance;
            self->cur_self_off is 0;
            self->cur_fn_name_start is VecInt.get(funcs, fi * 12 + 4);
            self->cur_fn_name_len is VecInt.get(funcs, fi * 12 + 5);
            self->cur_fn_ret_ty is VecInt.get(funcs, fi * 12 + 6);

            pstart is VecInt.get(funcs, fi * 12 + 7);
            pend is VecInt.get(funcs, fi * 12 + 8);
            ppos is pstart;
            pi is 0;
            while (ppos < pend) {
                if (VecToken.get_kind(self->toks, ppos) != TK_IDENT) { break; }
                base_is_string is Codegen.tok_is_string_kw(self, ppos);
                base_is_char is Codegen.tok_is_char_kw(self, ppos);
                pty is TY_INT;
                if (base_is_string == 1) { pty is TY_STRING; }
                ppos is ppos + 1;
                starc is 0;
                while (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 42) == 1) { starc is starc + 1; ppos is ppos + 1; }
                if (VecToken.get_kind(self->toks, ppos) != TK_IDENT) { cg_error("bad param"); }
                ns is VecToken.get_start(self->toks, ppos);
                nl is VecToken.get_len(self->toks, ppos);
                ppos is ppos + 1;
                has_arr is 0;
                if (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 91) == 1) {
                    if (Codegen.tok_punct1(self, ppos + 1, 93) == 1) { ppos is ppos + 2; }
                    has_arr is 1;
                }

                if (fn_kind == 1 && fn_is_instance == 1 && pi == 0) {
                    pty is TY_CLASS_BASE + fn_class_idx;
                } else if (base_is_char == 1 && starc > 0 && has_arr == 1) {
                    pty is TY_STR_ARR;
                } else if (base_is_char == 1 && starc > 0) {
                    pty is TY_STRING;
                }

	                off is (pi + 1) * self->word_size;
	                Codegen.vars_add(self, ns, nl, pty, off, 0);
	                if (fn_kind == 1 && fn_is_instance == 1 && pi == 0) { self->cur_self_off is off; }
	
	                # Move args into our stack slots (so later loads/stores use -off(%bp)).
	                if (self->bitness == 32) {
	                    Codegen.emit_str(self, "    movl ");
	                    Codegen.emit_dec(self, 8 + pi * 4);
	                    Codegen.emit_line(self, "(%ebp), %eax");
	                    Codegen.emit_str(self, "    movl %eax, -");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%ebp)");
	                } else {
	                    Codegen.emit_str(self, "    movq ");
	                    if (pi == 0) { Codegen.emit_str(self, "%rdi"); }
	                    else if (pi == 1) { Codegen.emit_str(self, "%rsi"); }
	                    else if (pi == 2) { Codegen.emit_str(self, "%rdx"); }
	                    else if (pi == 3) { Codegen.emit_str(self, "%rcx"); }
	                    else if (pi == 4) { Codegen.emit_str(self, "%r8"); }
	                    else if (pi == 5) { Codegen.emit_str(self, "%r9"); }
	                    else { cg_error("params > 6 not supported"); }
	                    Codegen.emit_str(self, ", -");
	                    Codegen.emit_dec(self, off);
	                    Codegen.emit_line(self, "(%rbp)");
	                }

                pi is pi + 1;
                if (VecToken.get_kind(self->toks, ppos) == TK_PUNCT && Codegen.tok_punct1(self, ppos, 44) == 1) { ppos is ppos + 1; continue; }
                break;
            }

            self->emit is 1;
            bstart is VecInt.get(funcs, fi * 12 + 9);
            bend is VecInt.get(funcs, fi * 12 + 10);
            Codegen.parse_stmt_list(self, bstart, bend);

	            # default return value if control falls through
	            Codegen.emit_line_bitness(self, "    xorq %rax, %rax", "    xorl %eax, %eax");
	            Codegen.emit_str(self, ".Lret_");
	            Codegen.emit_dec(self, self->cur_ret_label);
	            Codegen.emit_line(self, ":");
	            if (self->bitness == 32) {
	                if (local_bytes > 0) {
	                    Codegen.emit_str(self, "    addl $");
	                    Codegen.emit_dec(self, local_bytes);
	                    Codegen.emit_line(self, ", %esp");
	                }
	                Codegen.emit_line(self, "    popl %ebx");
	                Codegen.emit_line(self, "    movl %ebp, %esp");
	                Codegen.emit_line(self, "    popl %ebp");
	                Codegen.emit_line(self, "    ret");
	            } else {
	                Codegen.emit_line(self, "    movq %rbp, %rsp");
	                Codegen.emit_line(self, "    popq %rbp");
	                Codegen.emit_line(self, "    retq");
	            }

            self->emit is 0;
        }

        file_close(fd);

        # Cleanup compile-time tables (keeps memory bounded for large projects).
        self->fns is 0;
        self->globals is 0;
        self->classes is 0;
        self->fields is 0;

        VecInt.destroy(funcs);
        free(funcs);
        VecInt.destroy(globals);
        free(globals);
        VecInt.destroy(classes);
        free(classes);
        VecInt.destroy(fields);
        free(fields);
        VecInt.destroy(enums);
        free(enums);
        VecInt.destroy(enum_vals);
        free(enum_vals);

        VecInt.destroy(func_locals);
        free(func_locals);
        VecInt.destroy(func_params);
        free(func_params);
        VecInt.destroy(func_retlabels);
        free(func_retlabels);
    }
}

func void codegen_basic(string src, int* toks, int tok_count, int debug, int bitness, string out_path) {
    cg is Codegen();
    Codegen.init(cg, src, toks, tok_count, debug, bitness);
    Codegen.compile(cg, out_path);
}
